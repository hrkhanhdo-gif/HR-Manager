/**
 * Handler cho Telegram Bot messages
 * Gọi từ doPost khi nhận webhook từ Telegram
 * @param {Object} update - Telegram update object
 */
function handleTelegramUpdate_(update) {
  try {
    const message = update.message || update.callback_query?.message;
    if (!message) return;

    const chatId = message.chat.id;
    const text = (update.message?.text || '').trim();
    const callbackData = update.callback_query?.data;
    const fromUser = update.message?.from || update.callback_query?.from;

    // Kiểm tra quyền (chỉ admin/HR đã đăng ký mới dùng bot)
    const approvedChats = (PropertiesService.getScriptProperties().getProperty('TELEGRAM_APPROVED_CHATS') || '')
      .split(',').map(s => s.trim());
    if (!approvedChats.includes(String(chatId)) && chatId.toString() !== PropertiesService.getScriptProperties().getProperty('TELEGRAM_CHAT_ID')) {
      sendTelegramMessage_('❌ Bạn chưa được cấp quyền sử dụng bot này.', chatId);
      return;
    }

    // Handle callback buttons (approve/reject leave)
    if (callbackData) {
      handleTelegramCallback_(callbackData, chatId, fromUser);
      return;
    }

    // Handle commands
    if (text.startsWith('/start') || text.startsWith('/help')) {
      sendTelegramMessage_(getTelegramHelpText_(), chatId);
    } else if (text.startsWith('/pending')) {
      handleTelegramPendingLeaves_(chatId);
    } else if (text.startsWith('/stats')) {
      handleTelegramStats_(chatId);
    } else if (text.startsWith('/interview')) {
      handleTelegramInterviews_(chatId);
    } else if (text.startsWith('/birthday')) {
      handleTelegramBirthdays_(chatId);
    } else {
      sendTelegramMessage_('❓ Tôi không hiểu lệnh này. Gõ /help để xem danh sách lệnh.', chatId);
    }
  } catch (e) {
    Logger.log('handleTelegramUpdate_ error: ' + e.message);
  }
}

function getTelegramHelpText_() {
  return `<b>🤖 HRIS Bot — Danh sách lệnh</b>

/pending — Đơn nghỉ phép chờ duyệt
/stats — Thống kê nhanh hôm nay
/interview — Lịch phỏng vấn hôm nay
/birthday — Sinh nhật trong tuần
/help — Danh sách lệnh này

<i>Bot tự động từ HRIS System</i>`;
}

function handleTelegramPendingLeaves_(chatId) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('LEAVE_REQUESTS');
    if (!sheet) {
      sendTelegramMessage_('📋 Chưa có dữ liệu nghỉ phép.', chatId);
      return;
    }

    const data = sheet.getDataRange().getValues();
    const headers = data[0];
    const colId = headers.indexOf('ID_Leave');
    const colNS = headers.indexOf('ID_NhanSu');
    const colType = headers.indexOf('Leave_Type');
    const colFrom = headers.indexOf('From_Date');
    const colTo = headers.indexOf('To_Date');
    const colStatus = headers.indexOf('Status');

    const pending = data.filter((r, i) => i > 0 && r[colStatus] === 'Pending');

    if (pending.length === 0) {
      sendTelegramMessage_('✅ Không có đơn nào đang chờ duyệt.', chatId);
      return;
    }

    let text = `<b>📋 ${pending.length} đơn đang chờ duyệt</b>\n\n`;
    pending.slice(0, 5).forEach(r => {
      text += `• <b>${r[colNS]}</b> — ${r[colType]}\n  Từ: ${r[colFrom]} → ${r[colTo]}\n  ID: <code>${r[colId]}</code>\n\n`;
    });
    if (pending.length > 5) text += `<i>... và ${pending.length - 5} đơn khác</i>`;

    // Inline keyboard để duyệt từng đơn
    const keyboard = {
      inline_keyboard: pending.slice(0, 3).map(r => ([
        { text: `✅ Duyệt ${r[colId]}`, callback_data: `approve:${r[colId]}` },
        { text: `❌ Từ chối`, callback_data: `reject:${r[colId]}` }
      ]))
    };

    sendTelegramMessage_(text, chatId, keyboard);
  } catch (e) {
    Logger.log('handleTelegramPendingLeaves_ error: ' + e.message);
    sendTelegramMessage_('❌ Lỗi khi lấy dữ liệu: ' + e.message, chatId);
  }
}

function handleTelegramCallback_(callbackData, chatId, fromUser) {
  try {
    const [action, leaveId] = callbackData.split(':');
    if (!action || !leaveId) return;

    // Map approver từ Telegram user
    const approverEmail = PropertiesService.getScriptProperties().getProperty('TG_USER_' + fromUser.id) 
      || 'telegram@hris.system';

    const newStatus = action === 'approve' ? 'Approved' : 'Rejected';
    const result = approveLeaveRequest(leaveId, newStatus, approverEmail);

    if (result.success) {
      const icon = action === 'approve' ? '✅' : '❌';
      sendTelegramMessage_(`${icon} Đã <b>${action === 'approve' ? 'phê duyệt' : 'từ chối'}</b> đơn <code>${leaveId}</code>`, chatId);
    } else {
      sendTelegramMessage_(`❌ Lỗi: ${result.error}`, chatId);
    }
  } catch (e) {
    Logger.log('handleTelegramCallback_ error: ' + e.message);
  }
}

function handleTelegramStats_(chatId) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const nsSheet = ss.getSheetByName('NHAN_SU');
    const uvSheet = ss.getSheetByName('UNG_VIEN');

    if (!nsSheet) {
      sendTelegramMessage_('❌ Không có dữ liệu nhân sự.', chatId);
      return;
    }

    const nsData = nsSheet.getDataRange().getValues();
    const nsHeaders = nsData[0];
    const colStatus = nsHeaders.indexOf('Trang_Thai');

    let active = 0, probation = 0;
    for (let i = 1; i < nsData.length; i++) {
      const s = nsData[i][colStatus];
      if (s === 'Chính thức') active++;
      else if (s === 'Thử việc') probation++;
    }

    let uvPending = 0;
    if (uvSheet) {
      const uvData = uvSheet.getDataRange().getValues();
      const uvHeaders = uvData[0];
      const colUvStatus = uvHeaders.indexOf('Trang_Thai');
      uvPending = uvData.filter((r, i) => i > 0 && ['Mới nộp', 'Đang xét', 'Hẹn PV'].includes(r[colUvStatus])).length;
    }

    const text = `<b>📊 Thống kê HRIS hôm nay</b>
${Utilities.formatDate(new Date(), 'Asia/Ho_Chi_Minh', 'dd/MM/yyyy HH:mm')}

👥 Nhân viên chính thức: <b>${active}</b>
🔄 Đang thử việc: <b>${probation}</b>
📋 Ứng viên đang xử lý: <b>${uvPending}</b>
📝 Tổng nhân sự (kể cả đã nghỉ): <b>${nsData.length - 1}</b>

<i>Từ HRIS System</i>`;

    sendTelegramMessage_(text, chatId);
  } catch (e) {
    Logger.log('handleTelegramStats_ error: ' + e.message);
    sendTelegramMessage_('❌ Lỗi khi lấy thống kê.', chatId);
  }
}

function handleTelegramInterviews_(chatId) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('PHONG_VAN');
    if (!sheet) {
      sendTelegramMessage_('📋 Chưa có dữ liệu phỏng vấn.', chatId);
      return;
    }

    const data = sheet.getDataRange().getValues();
    const headers = data[0];
    const today = Utilities.formatDate(new Date(), 'Asia/Ho_Chi_Minh', 'dd/MM/yyyy');

    const todayInterviews = data.filter((r, i) => {
      if (i === 0) return false;
      const ngay = r[headers.indexOf('Ngay_PV')];
      if (!ngay) return false;
      return Utilities.formatDate(new Date(ngay), 'Asia/Ho_Chi_Minh', 'dd/MM/yyyy') === today;
    });

    if (todayInterviews.length === 0) {
      sendTelegramMessage_(`📅 Hôm nay (${today}) không có lịch phỏng vấn.`, chatId);
      return;
    }

    let text = `<b>📅 ${todayInterviews.length} phỏng vấn hôm nay (${today})</b>\n\n`;
    todayInterviews.forEach(r => {
      text += `• <b>${r[headers.indexOf('Ho_Ten_UV')]}</b>\n  ⏰ ${r[headers.indexOf('Gio_PV')]} | ${r[headers.indexOf('Hinh_Thuc')]}\n  👤 ${r[headers.indexOf('Nguoi_PV')]}\n\n`;
    });

    sendTelegramMessage_(text, chatId);
  } catch (e) {
    Logger.log('handleTelegramInterviews_ error: ' + e.message);
  }
}

function handleTelegramBirthdays_(chatId) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('NHAN_SU');
    if (!sheet) return;

    const data = sheet.getDataRange().getValues();
    const headers = data[0];
    const colName = headers.indexOf('Ho_Ten');
    const colDob = headers.indexOf('Ngay_Sinh');
    const colBp = headers.indexOf('Bo_Phan');
    const colStatus = headers.indexOf('Trang_Thai');

    const today = new Date();
    const thisWeek = [];

    for (let i = 1; i < data.length; i++) {
      const row = data[i];
      if (row[colStatus] === 'Đã nghỉ') continue;
      const dob = new Date(row[colDob]);
      if (!dob) continue;

      // Kiểm tra sinh nhật trong 7 ngày tới
      for (let d = 0; d < 7; d++) {
        const checkDate = new Date(today);
        checkDate.setDate(today.getDate() + d);
        if (dob.getMonth() === checkDate.getMonth() && dob.getDate() === checkDate.getDate()) {
          thisWeek.push({
            name: row[colName],
            dept: row[colBp],
            daysLeft: d,
            date: Utilities.formatDate(checkDate, 'Asia/Ho_Chi_Minh', 'dd/MM')
          });
        }
      }
    }

    if (thisWeek.length === 0) {
      sendTelegramMessage_('🎂 Không có sinh nhật nào trong 7 ngày tới.', chatId);
      return;
    }

    let text = `<b>🎂 Sinh nhật tuần này</b>\n\n`;
    thisWeek.sort((a, b) => a.daysLeft - b.daysLeft).forEach(b => {
      const label = b.daysLeft === 0 ? '🎉 Hôm nay!' : `còn ${b.daysLeft} ngày`;
      text += `• <b>${b.name}</b> (${b.dept}) — ${b.date} <i>(${label})</i>\n`;
    });

    sendTelegramMessage_(text, chatId);
  } catch (e) {
    Logger.log('handleTelegramBirthdays_ error: ' + e.message);
  }
}



/**
 * Gửi thông báo lịch phỏng vấn ngày mai lên Slack
 * Chạy qua trigger mỗi tối 20:00
 */
function runSlackInterviewReminder() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('PHONG_VAN');
    if (!sheet) return;

    const data = sheet.getDataRange().getValues();
    const headers = data[0];
    const colNgay = headers.indexOf('Ngay_PV');
    const colGio = headers.indexOf('Gio_PV');
    const colUV = headers.indexOf('Ho_Ten_UV');
    const colNguoiPV = headers.indexOf('Nguoi_PV');
    const colHinhThuc = headers.indexOf('Hinh_Thuc');
    const colKetQua = headers.indexOf('Ket_Qua');

    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    const tomorrowStr = Utilities.formatDate(tomorrow, 'Asia/Ho_Chi_Minh', 'dd/MM/yyyy');

    const interviews = [];
    for (let i = 1; i < data.length; i++) {
      const row = data[i];
      const ngayPv = row[colNgay];
      if (!ngayPv) continue;
      const ngayPvStr = Utilities.formatDate(new Date(ngayPv), 'Asia/Ho_Chi_Minh', 'dd/MM/yyyy');
      if (ngayPvStr === tomorrowStr && row[colKetQua] === 'Chờ kết quả') {
        interviews.push({
          Ho_Ten_UV: row[colUV],
          Gio_PV: row[colGio],
          Nguoi_PV: row[colNguoiPV],
          Hinh_Thuc: row[colHinhThuc]
        });
      }
    }

    if (interviews.length === 0) return;

    let listText = interviews.map(iv =>
      `• *${iv.Ho_Ten_UV}* — ${iv.Gio_PV || '?'} | ${iv.Hinh_Thuc || 'Trực tiếp'} | Người PV: ${iv.Nguoi_PV || '—'}`
    ).join('\n');

    const blocks = [
      {
        type: 'header',
        text: { type: 'plain_text', text: `📅 ${interviews.length} lịch phỏng vấn ngày mai`, emoji: true }
      },
      { type: 'section', text: { type: 'mrkdwn', text: listText } },
      {
        type: 'context',
        elements: [{ type: 'mrkdwn', text: `Nhắc tự động từ HRIS — ${tomorrowStr}` }]
      }
    ];
    sendSlackBlocks_(blocks, `${interviews.length} phỏng vấn ngày mai (${tomorrowStr})`);
  } catch (e) {
    Logger.log('runSlackInterviewReminder error: ' + e.message);
  }
}


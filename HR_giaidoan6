/**
 * Gửi message đến Telegram
 * @param {string} text - Nội dung (HTML format)
 * @param {string} [chatId] - Override chat ID nếu cần
 * @param {Object} [keyboard] - Inline keyboard markup (optional)
 */
function sendTelegramMessage_(text, chatId, keyboard) {
  try {
    const props = PropertiesService.getScriptProperties();
    const token = props.getProperty('TELEGRAM_BOT_TOKEN');
    const defaultChatId = props.getProperty('TELEGRAM_CHAT_ID');
    const targetChatId = chatId || defaultChatId;

    if (!token || !targetChatId) {
      Logger.log('sendTelegramMessage_: Telegram chưa cấu hình');
      return { success: false, error: 'Chưa cấu hình Telegram' };
    }

    const payload = {
      chat_id: targetChatId,
      text: text,
      parse_mode: 'HTML'
    };
    if (keyboard) payload.reply_markup = JSON.stringify(keyboard);

    const url = `https://api.telegram.org/bot${token}/sendMessage`;
    const response = UrlFetchApp.fetch(url, {
      method: 'POST',
      contentType: 'application/json',
      payload: JSON.stringify(payload),
      muteHttpExceptions: true
    });

    const result = JSON.parse(response.getContentText());
    if (!result.ok) {
      Logger.log('Telegram error: ' + result.description);
      return { success: false, error: result.description };
    }
    return { success: true, messageId: result.result.message_id };
  } catch (e) {
    Logger.log('sendTelegramMessage_ error: ' + e.message);
    return { success: false, error: e.message };
  }
}


/**
 * Xử lý các action của GĐ6 từ frontend
 * Thêm case này vào switch của handleRequest() trong GĐ1
 */
function handleGd6Action_(action, data, userEmail, userRole) {
  switch (action) {
    // PWA
    case 'getPwaManifest':
      return { success: true, manifest: getPwaManifest() };

    // Calendar
    case 'createCalendarPV':
      if (!hasPermission_(userEmail, ['ADMIN', 'HR'])) return { success: false, error: 'Không có quyền' };
      return createCalendarEventPhongVan(data);
    case 'createCalendarSinhNhat':
      if (!hasPermission_(userEmail, ['ADMIN', 'HR'])) return { success: false, error: 'Không có quyền' };
      return createCalendarEventSinhNhat(data);
    case 'createCalendarOnboarding':
      if (!hasPermission_(userEmail, ['ADMIN', 'HR'])) return { success: false, error: 'Không có quyền' };
      return createCalendarEventOnboarding(data);
    case 'bulkBirthdaySync':
      if (!hasPermission_(userEmail, ['ADMIN'])) return { success: false, error: 'Chỉ Admin mới chạy được' };
      return runBulkBirthdayCalendarSync();

    // Leave
    case 'approveLeave':
      return approveLeaveRequest(data.leaveId, data.action, userEmail);
    case 'getLeaveRequests':
      return getLeaveRequests_(userEmail, userRole, data);

    // Notifications
    case 'getActivityFeed':
      return getActivityFeed(data?.limit || 20);
    case 'getUnreadNotifications':
      return getUnreadNotifications();
    case 'markNotificationsRead':
      return markNotificationsRead();

    // Preferences
    case 'getUserPreferences':
      return getUserPreferences();
    case 'setLanguage':
      return setUserLanguageAndGetPrefs(data.lang);
    case 'setDarkMode':
      return setUserDarkMode(userEmail, data.isDark);

    // Slack test
    case 'testSlack':
      if (!hasPermission_(userEmail, ['ADMIN'])) return { success: false, error: 'Không có quyền' };
      return sendSlackMessage_('🧪 Test từ HRIS — ' + new Date().toLocaleString('vi-VN'), 'general');

    // Telegram test
    case 'testTelegram':
      if (!hasPermission_(userEmail, ['ADMIN'])) return { success: false, error: 'Không có quyền' };
      return sendTelegramMessage_('🧪 <b>Test từ HRIS</b>\n' + new Date().toLocaleString('vi-VN'));

    // Setup (Admin only)
    case 'setupLeaveForm':
      if (!hasPermission_(userEmail, ['ADMIN'])) return { success: false, error: 'Chỉ Admin' };
      return setupLeaveRequestForm();
    case 'setupAttendanceForm':
      if (!hasPermission_(userEmail, ['ADMIN'])) return { success: false, error: 'Chỉ Admin' };
      return setupAttendanceForm();
    case 'setSlackWebhook':
      if (!hasPermission_(userEmail, ['ADMIN'])) return { success: false, error: 'Chỉ Admin' };
      return setSlackWebhook(data.webhookUrl);
    case 'setTeamsWebhook':
      if (!hasPermission_(userEmail, ['ADMIN'])) return { success: false, error: 'Chỉ Admin' };
      return setTeamsWebhook(data.webhookUrl);
    case 'setTelegramConfig':
      if (!hasPermission_(userEmail, ['ADMIN'])) return { success: false, error: 'Chỉ Admin' };
      return setTelegramConfig(data.botToken, data.chatId);
    case 'setTelegramWebhook':
      if (!hasPermission_(userEmail, ['ADMIN'])) return { success: false, error: 'Chỉ Admin' };
      return setTelegramWebhook();

    default:
      return null; // Không phải GĐ6 action, pass sang handler khác
  }
}

/**
 * Lấy danh sách đơn nghỉ phép (có filter theo role)
 */
function getLeaveRequests_(userEmail, userRole, filters) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('LEAVE_REQUESTS');
    if (!sheet) return { success: true, data: [] };

    const data = sheet.getDataRange().getValues();
    const headers = data[0];
    const colNS = headers.indexOf('ID_NhanSu');
    const colEmail = headers.indexOf('Email_NhanSu');
    const colStatus = headers.indexOf('Status');

    let rows = data.slice(1).map(r => {
      const obj = {};
      headers.forEach((h, i) => obj[h] = r[i]);
      return obj;
    });

    // Filter theo role
    if (userRole === 'EMPLOYEE') {
      rows = rows.filter(r => r['Email_NhanSu'] === userEmail);
    } else if (userRole === 'MANAGER') {
      // Manager chỉ thấy bộ phận của mình — cần join với NHAN_SU
      // Simplified: thấy tất cả pending
      rows = rows.filter(r => r['Status'] === 'Pending');
    }

    // Filter theo status nếu có
    if (filters?.status) rows = rows.filter(r => r['Status'] === filters.status);

    return { success: true, data: rows.reverse().slice(0, 100) };
  } catch (e) {
    Logger.log('getLeaveRequests_ error: ' + e.message);
    return { success: false, error: e.message };
  }
}



        <button class="btn btn-primary" onclick="saveTeamsWebhook()" style="white-space:nowrap;">Lưu</button>
      </div>
    </div>

    <!-- Telegram -->
    <div class="form-group" style="margin-bottom:20px;">
      <label class="form-label" style="font-weight:700;color:#1A1A1A;">✈️ Telegram Bot</label>
      <div class="form-row">
        <input type="text" id="tgTokenInput" class="form-control" placeholder="Bot Token (từ @BotFather)" style="flex:1;">
        <input type="text" id="tgChatIdInput" class="form-control" placeholder="Chat ID" style="width:160px;">
        <button class="btn btn-primary" onclick="saveTelegramConfig()" style="white-space:nowrap;">Lưu</button>
        <button class="btn btn-ghost" onclick="testTelegram()" style="white-space:nowrap;">Test</button>
      </div>
      <button class="btn btn-ghost" style="margin-top:8px;font-size:13px;" onclick="registerTelegramWebhook()">
        🔗 Đăng ký Webhook Telegram
      </button>
    </div>

    <!-- Language -->
    <div class="form-group" style="margin-bottom:20px;">
      <label class="form-label" style="font-weight:700;color:#1A1A1A;">🌐 Ngôn ngữ</label>
      <div style="display:flex;gap:10px;">
        <button class="btn" id="langViBtn" onclick="switchLanguage('vi')" style="border:2px solid #3D35A8;color:#3D35A8;">🇻🇳 Tiếng Việt</button>
        <button class="btn btn-ghost" id="langEnBtn" onclick="switchLanguage('en')">🇬🇧 English</button>
      </div>
    </div>

    <!-- Dark Mode -->
    <div class="form-group" style="margin-bottom:20px;">
      <label class="form-label" style="font-weight:700;color:#1A1A1A;">🌙 Giao diện</label>
      <div style="display:flex;align-items:center;gap:12px;">
        <label class="toggle-switch" style="display:flex;align-items:center;gap:10px;cursor:pointer;">
          <input type="checkbox" id="darkModeCheckbox" onchange="toggleDarkMode()" style="display:none;">
          <div id="darkModeToggleSlider" style="width:48px;height:26px;background:#ccc;border-radius:13px;position:relative;transition:.2s;">
            <div style="position:absolute;top:3px;left:3px;width:20px;height:20px;background:white;border-radius:50%;transition:.2s;" id="darkSliderKnob"></div>
          </div>
          <span style="font-size:14px;color:#555;">Chế độ tối</span>
        </label>
      </div>
    </div>

    <!-- Google Forms -->
    <div class="form-group">
      <label class="form-label" style="font-weight:700;color:#1A1A1A;">📋 Google Forms</label>
      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <button class="btn btn-ghost" onclick="setupLeaveForm()">📝 Tạo Form Nghỉ phép</button>
        <button class="btn btn-ghost" onclick="setupAttendanceForm()">🕐 Tạo Form Chấm công</button>
        <button class="btn btn-ghost" onclick="syncBirthdayCalendar()">🎂 Sync Sinh nhật → Calendar</button>
      </div>
    </div>

  </div>
</div>
`.trim();
}

/**
 * JavaScript cho Settings page
 */
function getSettingsJs() {
  return `
// ─── Settings GĐ6 JS ───
function saveSlackWebhook() {
  const url = document.getElementById('slackWebhookInput')?.value?.trim();
  if (!url || !url.startsWith('https://hooks.slack.com/')) {
    showToast('URL Slack không hợp lệ', 'error'); return;
  }
  callApi('setSlackWebhook', { webhookUrl: url }, 
    () => showToast('✅ Đã lưu Slack webhook', 'success'),
    err => showToast('❌ Lỗi: ' + err, 'error'));
}

function testSlack() {
  callApi('testSlack', {}, 
    res => showToast(res.success ? '✅ Slack hoạt động!' : '❌ ' + res.error, res.success ? 'success' : 'error'),
    err => showToast('❌ Lỗi: ' + err, 'error'));
}

function saveTeamsWebhook() {
  const url = document.getElementById('teamsWebhookInput')?.value?.trim();
  if (!url) { showToast('Vui lòng nhập URL', 'error'); return; }
  callApi('setTeamsWebhook', { webhookUrl: url },
    () => showToast('✅ Đã lưu Teams webhook', 'success'),
    err => showToast('❌ ' + err, 'error'));
}

function saveTelegramConfig() {
  const token = document.getElementById('tgTokenInput')?.value?.trim();
  const chatId = document.getElementById('tgChatIdInput')?.value?.trim();
  if (!token || !chatId) { showToast('Vui lòng nhập đủ Bot Token và Chat ID', 'error'); return; }
  callApi('setTelegramConfig', { botToken: token, chatId },
    () => showToast('✅ Đã lưu Telegram config', 'success'),
    err => showToast('❌ ' + err, 'error'));
}

function testTelegram() {
  callApi('testTelegram', {},
    res => showToast(res.success ? '✅ Telegram hoạt động!' : '❌ ' + res.error, res.success ? 'success' : 'error'),
    err => showToast('❌ ' + err, 'error'));
}

function registerTelegramWebhook() {
  callApi('setTelegramWebhook', {},
    res => showToast(res.success ? '✅ Webhook đã đăng ký' : '❌ ' + res.description, res.success ? 'success' : 'error'),
    err => showToast('❌ ' + err, 'error'));
}

function setupLeaveForm() {
  callApi('setupLeaveForm', {},
    res => {
      if (res.success) {
        showToast('✅ Đã tạo Form nghỉ phép!', 'success');
        if (res.formUrl) window.open(res.formUrl, '_blank');
      } else {
        showToast('❌ ' + res.error, 'error');
      }
    },
    err => showToast('❌ ' + err, 'error'));
}

function setupAttendanceForm() {
  callApi('setupAttendanceForm', {},
    res => {
      if (res.success) {
        showToast('✅ Đã tạo Form chấm công!', 'success');
        if (res.formUrl) window.open(res.formUrl, '_blank');
      } else {
        showToast('❌ ' + res.error, 'error');
      }
    },
    err => showToast('❌ ' + err, 'error'));
}

function syncBirthdayCalendar() {
  showToast('Đang sync sinh nhật...', 'info');
  callApi('bulkBirthdaySync', {},
    res => showToast(res.success ? '✅ Sync xong! ' + res.created + ' event đã tạo' : '❌ ' + res.error, res.success ? 'success' : 'error'),
    err => showToast('❌ ' + err, 'error'));
}

// Dark Mode slider
function initDarkModeSlider(isDark) {
  const cb = document.getElementById('darkModeCheckbox');
  const knob = document.getElementById('darkSliderKnob');
  const slider = document.getElementById('darkModeToggleSlider');
  if (!cb) return;
  cb.checked = isDark;
  if (isDark) {
    if (slider) slider.style.background = '#3D35A8';
    if (knob) knob.style.left = '25px';
  }
}

// Override toggleDarkMode để update slider cũng
const _origToggleDark = window.toggleDarkMode;
window.toggleDarkMode = function() {
  _origToggleDark && _origToggleDark();
  const isDark = document.documentElement.classList.contains('dark-mode');
  const knob = document.getElementById('darkSliderKnob');
  const slider = document.getElementById('darkModeToggleSlider');
  if (slider) slider.style.background = isDark ? '#3D35A8' : '#ccc';
  if (knob) knob.style.left = isDark ? '25px' : '3px';
};
`.trim();
}

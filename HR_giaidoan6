/**
 * Gửi message đến Slack channel
 * @param {string} text - Nội dung message (Slack markdown)
 * @param {string} channel - Channel name (optional, nếu webhook cố định channel)
 * @param {Object[]} [attachments] - Slack attachments/blocks (optional)
 */
function sendSlackMessage_(text, channel, attachments) {
  try {
    const webhookUrl = PropertiesService.getScriptProperties().getProperty('SLACK_WEBHOOK_URL');
    if (!webhookUrl) {
      Logger.log('sendSlackMessage_: SLACK_WEBHOOK_URL chưa được cấu hình');
      return { success: false, error: 'Chưa cấu hình Slack webhook' };
    }

    const payload = { text };
    if (channel) payload.channel = '#' + channel.replace('#', '');
    if (attachments && attachments.length > 0) payload.attachments = attachments;

    const response = UrlFetchApp.fetch(webhookUrl, {
      method: 'POST',
      contentType: 'application/json',
      payload: JSON.stringify(payload),
      muteHttpExceptions: true
    });

    if (response.getResponseCode() !== 200) {
      Logger.log('Slack error: ' + response.getContentText());
      return { success: false, error: response.getContentText() };
    }
    return { success: true };
  } catch (e) {
    Logger.log('sendSlackMessage_ error: ' + e.message);
    return { success: false, error: e.message };
  }
}


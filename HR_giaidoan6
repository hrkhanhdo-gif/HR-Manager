/**
 * JavaScript cho PWA + Mobile (inject vào script section của HTML)
 */
function getPwaJs() {
  return `
// ─── PWA + Mobile JS (Module 27) ───

let _pwaInstallPrompt = null;

function initPwa() {
  // Service Worker via Blob (workaround vì GAS không host file tĩnh)
  if ('serviceWorker' in navigator) {
    const swCode = ${JSON.stringify(getServiceWorkerScript())};
    const blob = new Blob([swCode], { type: 'application/javascript' });
    const swUrl = URL.createObjectURL(blob);
    navigator.serviceWorker.register(swUrl)
      .then(reg => console.log('SW registered:', reg.scope))
      .catch(err => console.log('SW error:', err));
  }

  // PWA install prompt
  window.addEventListener('beforeinstallprompt', e => {
    e.preventDefault();
    _pwaInstallPrompt = e;
    const banner = document.getElementById('pwaInstallBanner');
    if (banner && !localStorage.getItem('pwa_dismissed')) {
      setTimeout(() => banner.classList.remove('hidden'), 3000);
    }
  });

  window.addEventListener('appinstalled', () => {
    document.getElementById('pwaInstallBanner')?.classList.add('hidden');
    showToast('✅ HRIS đã được cài đặt!', 'success');
  });

  // Manifest meta tags
  const meta = document.createElement('meta');
  meta.name = 'theme-color'; meta.content = '#3D35A8';
  document.head.appendChild(meta);
  const appMeta = document.createElement('meta');
  appMeta.name = 'apple-mobile-web-app-capable'; appMeta.content = 'yes';
  document.head.appendChild(appMeta);
  const statusMeta = document.createElement('meta');
  statusMeta.name = 'apple-mobile-web-app-status-bar-style'; statusMeta.content = 'black-translucent';
  document.head.appendChild(statusMeta);
}

function triggerPwaInstall() {
  if (_pwaInstallPrompt) {
    _pwaInstallPrompt.prompt();
    _pwaInstallPrompt.userChoice.then(choice => {
      if (choice.outcome === 'accepted') showToast('✅ Đang cài HRIS...', 'success');
      _pwaInstallPrompt = null;
    });
  }
}

function dismissPwaBanner() {
  document.getElementById('pwaInstallBanner')?.classList.add('hidden');
  localStorage.setItem('pwa_dismissed', '1');
}

function setBottomActive(el) {
  document.querySelectorAll('.bottom-nav-item').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
}

// Init khi DOM sẵn sàng
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initPwa);
} else {
  initPwa();
}
`.trim();
}



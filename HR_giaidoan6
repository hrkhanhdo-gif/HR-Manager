}

/**
 * Bulk tạo event sinh nhật cho tất cả nhân viên đang hoạt động
 * Chạy thủ công 1 lần/năm hoặc qua trigger đầu năm
 */
function runBulkBirthdayCalendarSync() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('NHAN_SU');
    if (!sheet) throw new Error('Sheet NHAN_SU không tồn tại');

    const data = sheet.getDataRange().getValues();
    const headers = data[0];
    const colIdx = (name) => headers.indexOf(name);

    let created = 0, skipped = 0, errors = 0;

    for (let i = 1; i < data.length; i++) {
      const row = data[i];
      const status = row[colIdx('Trang_Thai')];
      if (status === 'Đã nghỉ') continue;

      const ngaySinh = row[colIdx('Ngay_Sinh')];
      if (!ngaySinh) continue;

      const result = createCalendarEventSinhNhat({
        ID_NhanSu: row[colIdx('ID_NhanSu')],
        Ho_Ten: row[colIdx('Ho_Ten')],
        Ngay_Sinh: ngaySinh,
        Bo_Phan: row[colIdx('Bo_Phan')]
      });

      if (result.success && !result.skipped) created++;
      else if (result.skipped) skipped++;
      else errors++;

      Utilities.sleep(200); // Tránh quota
    }

    Logger.log(`Bulk birthday sync: created=${created}, skipped=${skipped}, errors=${errors}`);
    return { success: true, created, skipped, errors };
  } catch (e) {
    Logger.log('runBulkBirthdayCalendarSync error: ' + e.message);
    writeAuditLog_('SYSTEM', 'SYSTEM', 'ERROR', 'CALENDAR', 'BULK_BIRTHDAY', '', '', '', e.message);
    return { success: false, error: e.message };
  }
}



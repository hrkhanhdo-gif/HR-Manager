/**
 * Trigger handler khi form xin nghỉ phép được submit
 * @param {Object} e - FormSubmit event
 */
function onLeaveFormSubmit(e) {
  try {
    const responses = e.response.getItemResponses();
    const email = e.response.getRespondentEmail();

    // Parse responses theo thứ tự field
    const idNhanSu   = responses[0]?.getResponse() || '';
    const leaveType  = responses[1]?.getResponse() || '';
    const fromDate   = responses[2]?.getResponse() || '';
    const toDate     = responses[3]?.getResponse() || '';
    const reason     = responses[4]?.getResponse() || '';
    const handover   = responses[5]?.getResponse() || '';

    if (!idNhanSu || !leaveType || !fromDate || !toDate) {
      Logger.log('onLeaveFormSubmit: thiếu dữ liệu bắt buộc');
      return;
    }

    // Parse leave type
    const leaveTypeMap = {
      'Nghỉ phép năm (Annual)': 'Annual',
      'Nghỉ bệnh (Sick)': 'Sick',
      'Nghỉ không lương (Unpaid)': 'Unpaid',
      'Nghỉ thai sản (Maternity)': 'Maternity',
      'Nghỉ việc riêng': 'Other'
    };

    // Lưu vào sheet LEAVE_REQUESTS
    const result = createLeaveRequest_({
      ID_NhanSu: idNhanSu,
      Email_NhanSu: email,
      Leave_Type: leaveTypeMap[leaveType] || 'Other',
      From_Date: fromDate,
      To_Date: toDate,
      Reason: reason + (handover ? '\nBàn giao: ' + handover : ''),
      Status: 'Pending'
    });

    if (result.success) {
      // Gửi email xác nhận cho nhân viên
      sendLeaveConfirmationEmail_(email, idNhanSu, leaveType, fromDate, toDate, result.leaveId);
      // Gửi email yêu cầu duyệt cho HR/Manager
      sendLeaveApprovalRequestEmail_(result.leaveId, idNhanSu, leaveType, fromDate, toDate, reason);
      // Thông báo Slack (nếu đã cấu hình)
      sendSlackMessage_(`📋 *Đơn nghỉ phép mới*\nNhân viên: ${idNhanSu}\nLoại: ${leaveType}\nTừ: ${fromDate} → ${toDate}\nLý do: ${reason || '—'}`, 'hr-notifications');
    }
  } catch (e) {
    Logger.log('onLeaveFormSubmit error: ' + e.message);
    writeAuditLog_('FORM', 'SYSTEM', 'ERROR', 'LEAVE_REQUESTS', '', '', '', '', e.message);
  }
}

/**
 * Tạo bản ghi leave request trong sheet
 */
function createLeaveRequest_(data) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    let sheet = ss.getSheetByName('LEAVE_REQUESTS');
    if (!sheet) {
      sheet = ss.insertSheet('LEAVE_REQUESTS');
      sheet.appendRow(['ID_Leave', 'ID_NhanSu', 'Email_NhanSu', 'Leave_Type', 'From_Date', 'To_Date', 'Days', 'Reason', 'Approver', 'Status', 'Approved_At', 'Created_At']);
    }

    const now = new Date();
    const leaveId = 'LV-' + Utilities.formatDate(now, 'Asia/Ho_Chi_Minh', 'yyyyMMdd') + '-' + String(sheet.getLastRow()).padStart(4, '0');

    const from = new Date(data.From_Date);
    const to = new Date(data.To_Date);
    const days = Math.max(1, Math.round((to - from) / (1000 * 60 * 60 * 24)) + 1);

    sheet.appendRow([
      leaveId,
      data.ID_NhanSu,
      data.Email_NhanSu || '',
      data.Leave_Type,
      data.From_Date,
      data.To_Date,
      days,
      data.Reason || '',
      '', // Approver (chưa có)
      'Pending',
      '', // Approved_At
      Utilities.formatDate(now, 'Asia/Ho_Chi_Minh', 'dd/MM/yyyy HH:mm:ss')
    ]);

    writeAuditLog_(data.Email_NhanSu || 'FORM', 'EMPLOYEE', 'CREATE', 'LEAVE_REQUESTS', leaveId, 'Status', '', 'Pending', 'Đơn xin nghỉ phép qua Form');
    return { success: true, leaveId, days };
  } catch (e) {
    Logger.log('createLeaveRequest_ error: ' + e.message);
    return { success: false, error: e.message };
  }
}

/**
 * Duyệt/Từ chối đơn nghỉ phép (gọi từ email link hoặc UI)
 * @param {string} leaveId
 * @param {string} action - 'Approved' | 'Rejected'
 * @param {string} approverEmail
 */
function approveLeaveRequest(leaveId, action, approverEmail) {
  try {
    if (!hasPermission_(approverEmail, ['ADMIN', 'HR', 'MANAGER'])) {
      return { success: false, error: 'Không có quyền phê duyệt' };
    }

    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('LEAVE_REQUESTS');
    if (!sheet) return { success: false, error: 'Sheet LEAVE_REQUESTS không tồn tại' };

    const data = sheet.getDataRange().getValues();
    const headers = data[0];
    const colId = headers.indexOf('ID_Leave');
    const colStatus = headers.indexOf('Status');
    const colApprover = headers.indexOf('Approver');
    const colApprovedAt = headers.indexOf('Approved_At');
    const colEmployee = headers.indexOf('Email_NhanSu');

    for (let i = 1; i < data.length; i++) {
      if (data[i][colId] === leaveId) {
        if (data[i][colStatus] !== 'Pending') {
          return { success: false, error: 'Đơn đã được xử lý rồi' };
        }
        const now = new Date();
        sheet.getRange(i + 1, colStatus + 1).setValue(action);
        sheet.getRange(i + 1, colApprover + 1).setValue(approverEmail);
        sheet.getRange(i + 1, colApprovedAt + 1).setValue(Utilities.formatDate(now, 'Asia/Ho_Chi_Minh', 'dd/MM/yyyy HH:mm:ss'));

        // Gửi email kết quả
        const employeeEmail = data[i][colEmployee];
        if (employeeEmail) {
          const actionText = action === 'Approved' ? '✅ đã được PHÊ DUYỆT' : '❌ đã bị TỪ CHỐI';
          MailApp.sendEmail({
            to: employeeEmail,
            subject: `[HRIS] Đơn nghỉ phép ${actionText}`,
            htmlBody: buildLeaveResultEmailHtml_(leaveId, action, approverEmail, data[i])
          });
        }

        // Slack notification
        const slackMsg = action === 'Approved'
          ? `✅ Đơn nghỉ phép *${leaveId}* đã được phê duyệt bởi ${approverEmail}`
          : `❌ Đơn nghỉ phép *${leaveId}* bị từ chối bởi ${approverEmail}`;
        sendSlackMessage_(slackMsg, 'hr-notifications');

        writeAuditLog_(approverEmail, getUserRole_(approverEmail), 'UPDATE', 'LEAVE_REQUESTS', leaveId, 'Status', 'Pending', action, '');
        return { success: true, leaveId, action };
      }
    }
    return { success: false, error: 'Không tìm thấy đơn nghỉ phép: ' + leaveId };
  } catch (e) {
    Logger.log('approveLeaveRequest error: ' + e.message);
    writeAuditLog_(approverEmail, '', 'ERROR', 'LEAVE_REQUESTS', leaveId, '', '', '', e.message);
    return { success: false, error: e.message };
  }
}


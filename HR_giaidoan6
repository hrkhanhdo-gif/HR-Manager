/**
 * Lấy activity feed từ AUDIT_LOG (200 bản ghi gần nhất, đã filter)
 * @param {number} [limit=20]
 * @returns {Object[]}
 */
function getActivityFeed(limit) {
  try {
    const maxRows = limit || 20;
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('AUDIT_LOG');
    if (!sheet) return { success: true, activities: [] };

    const data = sheet.getDataRange().getValues();
    const headers = data[0];
    const colTime = headers.indexOf('Thoi_Gian');
    const colEmail = headers.indexOf('Email');
    const colAction = headers.indexOf('Hanh_Dong');
    const colSheet = headers.indexOf('Sheet');
    const colId = headers.indexOf('ID_Ban_Ghi');
    const colField = headers.indexOf('Truong_Thay_Doi');
    const colOld = headers.indexOf('Gia_Tri_Cu');
    const colNew = headers.indexOf('Gia_Tri_Moi');
    const colNote = headers.indexOf('Ghi_Chu');

    // Filter bỏ ERROR và LOGIN routine, chỉ lấy thao tác thực
    const meaningful = ['CREATE', 'UPDATE', 'DELETE'];
    const filtered = data
      .slice(1)
      .filter(r => meaningful.includes(r[colAction]) && r[colSheet] && r[colSheet] !== 'AUDIT_LOG')
      .reverse() // Mới nhất trước
      .slice(0, maxRows);

    const activities = filtered.map(r => {
      const action = r[colAction];
      const sheetName = r[colSheet];
      const id = r[colId];
      const time = r[colTime];

      return {
        id: id + '_' + (time instanceof Date ? time.getTime() : time),
        time: time instanceof Date ? Utilities.formatDate(time, 'Asia/Ho_Chi_Minh', 'dd/MM HH:mm') : String(time),
        timestamp: time instanceof Date ? time.getTime() : 0,
        action,
        icon: action === 'CREATE' ? '➕' : action === 'UPDATE' ? '✏️' : '🗑️',
        color: action === 'CREATE' ? 'green' : action === 'UPDATE' ? 'purple' : 'red',
        actor: r[colEmail] ? r[colEmail].split('@')[0] : '—',
        actorFull: r[colEmail] || '',
        sheet: sheetName,
        sheetLabel: getSheetLabel_(sheetName),
        recordId: id,
        field: r[colField] || '',
        oldValue: r[colOld] || '',
        newValue: r[colNew] || '',
        note: r[colNote] || '',
        summary: buildActivitySummary_(action, sheetName, id, r[colField], r[colOld], r[colNew])
      };
    });

    return { success: true, activities };
  } catch (e) {
    Logger.log('getActivityFeed error: ' + e.message);
    return { success: false, error: e.message, activities: [] };
  }
}

/**
 * Lấy notification chưa đọc cho user hiện tại
 */
function getUnreadNotifications() {
  try {
    const email = Session.getActiveUser().getEmail();
    const lastRead = parseInt(PropertiesService.getUserProperties().getProperty('notif_last_read_' + email) || '0');

    const feedResult = getActivityFeed(50);
    if (!feedResult.success) return { success: true, count: 0, notifications: [] };

    const unread = feedResult.activities.filter(a => a.timestamp > lastRead);
    return { success: true, count: unread.length, notifications: unread.slice(0, 10) };
  } catch (e) {
    Logger.log('getUnreadNotifications error: ' + e.message);
    return { success: true, count: 0, notifications: [] };
  }
}


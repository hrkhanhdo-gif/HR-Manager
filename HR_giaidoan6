/**
 * Tạo event phỏng vấn trên Google Calendar
 * @param {Object} pvData - Dữ liệu từ sheet PHONG_VAN
 */
function createCalendarEventPhongVan(pvData) {
  try {
    const calendarId = getConfig_('CALENDAR_ID') || 'primary';
    const calendar = CalendarApp.getCalendarById(calendarId) || CalendarApp.getDefaultCalendar();

    const [h, m] = (pvData.Gio_PV || '09:00').split(':').map(Number);
    const startDate = new Date(pvData.Ngay_PV);
    startDate.setHours(h, m, 0, 0);
    const endDate = new Date(startDate.getTime() + 60 * 60 * 1000); // 1 giờ

    const title = `[PV] ${pvData.Ho_Ten_UV} — ${pvData.Vi_Tri_Tuyen || 'Vị trí ứng tuyển'}`;
    const desc = [
      `Ứng viên: ${pvData.Ho_Ten_UV}`,
      `Vị trí: ${pvData.Vi_Tri_Tuyen || '—'}`,
      `Hình thức: ${pvData.Hinh_Thuc || 'Trực tiếp'}`,
      `Người phỏng vấn: ${pvData.Nguoi_PV || '—'}`,
      `ID Phỏng vấn: ${pvData.ID_PV}`,
      '',
      'Tạo tự động bởi HRIS'
    ].join('\n');

    const options = {
      description: desc,
      location: pvData.Hinh_Thuc === 'Online' ? 'Google Meet / Zoom' : 'Văn phòng',
    };

    // Thêm guests nếu có email
    if (pvData.Email_UV) options.guests = pvData.Email_UV;

    const event = calendar.createEvent(title, startDate, endDate, options);

    writeAuditLog_(
      Session.getActiveUser().getEmail(),
      getUserRole_(Session.getActiveUser().getEmail()),
      'CREATE',
      'CALENDAR_EVENT',
      pvData.ID_PV,
      'event_id',
      '',
      event.getId(),
      'Tạo event phỏng vấn'
    );

    return { success: true, eventId: event.getId(), eventUrl: event.getEventSeriesId() };
  } catch (e) {
    Logger.log('createCalendarEventPhongVan error: ' + e.message);
    writeAuditLog_('SYSTEM', 'SYSTEM', 'ERROR', 'CALENDAR', pvData.ID_PV || '', '', '', '', e.message);
    return { success: false, error: e.message };
  }
}

/**
 * Tạo event sinh nhật hàng năm (recurring) cho nhân viên
 * @param {Object} nsData - { ID_NhanSu, Ho_Ten, Ngay_Sinh, Email }
 */
function createCalendarEventSinhNhat(nsData) {
  try {
    const calendar = CalendarApp.getDefaultCalendar();
    const dob = new Date(nsData.Ngay_Sinh);
    const thisYear = new Date().getFullYear();

    // Tạo event cho năm hiện tại
    const eventDate = new Date(thisYear, dob.getMonth(), dob.getDate());
    eventDate.setHours(8, 0, 0, 0);
    const eventEnd = new Date(eventDate.getTime() + 30 * 60 * 1000);

    const title = `🎂 Sinh nhật: ${nsData.Ho_Ten}`;
    const desc = `Nhân viên: ${nsData.Ho_Ten}\nBộ phận: ${nsData.Bo_Phan || '—'}\nTạo tự động bởi HRIS`;

    // Kiểm tra xem đã có event chưa để tránh duplicate
    const existing = calendar.getEvents(
      new Date(thisYear, dob.getMonth(), dob.getDate(), 0, 0),
      new Date(thisYear, dob.getMonth(), dob.getDate(), 23, 59),
      { search: nsData.Ho_Ten }
    );
    if (existing.length > 0) {
      return { success: true, skipped: true, reason: 'Event đã tồn tại' };
    }

    const event = calendar.createAllDayEvent(title, new Date(thisYear, dob.getMonth(), dob.getDate()), { description: desc });
    return { success: true, eventId: event.getId() };
  } catch (e) {
    Logger.log('createCalendarEventSinhNhat error: ' + e.message);
    return { success: false, error: e.message };
  }
}

/**
 * Tạo event deadline Onboarding Task
 * @param {Object} taskData - { ID_Task, Task_Name, Deadline, ID_NhanSu, Ho_Ten }

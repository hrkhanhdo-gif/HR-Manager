/**
 * Xuất bảng lương ra CSV string (có thể dán vào Google Sheets)
 */
function exportPayrollCsv(period) {
  const rows = getPayrollList({ period });
  if (rows.length === 0) return { success: false, error: 'Không có dữ liệu' };

  const headers = ['ID_NhanSu','Ho_Ten','Bo_Phan','Period','Basic_Salary',
    'Allowance','Bonus','Work_Days','Gross_Salary','BHXH_Employee',
    'BHYT_Employee','BHTN_Employee','Tax_PIT','Net_Salary','Status'];

  const lines = [headers.join(',')];
  rows.forEach(r => {
    lines.push(headers.map(h => {
      const v = r[h] !== undefined ? r[h] : '';
      return typeof v === 'string' && v.includes(',') ? `"${v}"` : v;
    }).join(','));
  });

  return { success: true, csv: lines.join('\n'), count: rows.length };
}

/**
 * Helper map ngày công từ ATTENDANCE theo nsId
 */
function getAttendanceMap(period) {
  const map = {};
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('ATTENDANCE');
    if (!sheet) return map;
    const data = sheet.getDataRange().getValues().slice(1);
    data.forEach(row => {
      if (row[3] === period) map[row[0]] = parseFloat(row[4]) || 26;
    });
  } catch (e) {}
  return map;
}

/**
 * Format số tiền VND
 */
function formatVnd(n) {
  return (parseFloat(n) || 0).toLocaleString('vi-VN') + ' đ';
}


function calcLeaveDays() {
  const from = document.getElementById('lv-from').value;
  const to   = document.getElementById('lv-to').value;
  if (!from || !to) return;
  const f = new Date(from); const t = new Date(to);
  if (t < f) { document.getElementById('lv-days-preview').style.display = 'none'; return; }
  let count = 0; const d = new Date(f);
  while (d <= t) { if (d.getDay() !== 0 && d.getDay() !== 6) count++; d.setDate(d.getDate() + 1); }
  document.getElementById('lv-days-count').textContent = count;
  document.getElementById('lv-days-preview').style.display = 'block';
}

function openLeaveModal() {
  document.getElementById('lv-days-preview').style.display = 'none';
  document.getElementById('lv-reason').value = '';
  document.getElementById('lv-approver').value = '';
  document.getElementById('modal-leave').style.display = 'flex';
}

function submitLeaveRequest() {
  const nsVal = document.getElementById('lv-ns').value;
  if (!nsVal) { showToast('Chọn nhân sự', 'error'); return; }
  const [nsId, hoTen, boPhan] = nsVal.split('|');
  const from = document.getElementById('lv-from').value;
  const to   = document.getElementById('lv-to').value;
  if (!from || !to) { showToast('Vui lòng chọn ngày nghỉ', 'error'); return; }
  showLoading();
  google.script.run
    .withSuccessHandler(res => {
      hideLoading();
      if (res.success) {
        showToast('Đã gửi đơn nghỉ (' + res.days + ' ngày) ✅');
        closeModal('modal-leave');
        loadLeaveTable();
      } else { showToast(res.error, 'error'); }
    })
    .handleRequest({
      action: 'CREATE_LEAVE_REQUEST',
      payload: {
        id_nhan_su: nsId, ho_ten: hoTen, bo_phan: boPhan,
        leave_type: document.getElementById('lv-type').value,
        from_date: from, to_date: to,
        reason: document.getElementById('lv-reason').value,
        approver: document.getElementById('lv-approver').value,
      }
    });
}

function approveLeave(id) {
  if (!confirm('Duyệt đơn nghỉ phép này?')) return;
  showLoading();
  google.script.run
    .withSuccessHandler(res => {
      hideLoading();
      if (res.success) { showToast(res.message + ' ✅'); loadLeaveTable(); }
      else showToast(res.error, 'error');
    })
    .handleRequest({ action: 'PROCESS_LEAVE_REQUEST', payload: { id, action: 'Approved' } });
}

function openRejectModal(id) {
  document.getElementById('reject-leave-id').value = id;
  document.getElementById('reject-reason').value = '';
  document.getElementById('modal-reject-leave').style.display = 'flex';
}

function submitRejectLeave() {
  const id     = document.getElementById('reject-leave-id').value;
  const reason = document.getElementById('reject-reason').value.trim();
  if (!reason) { showToast('Vui lòng nhập lý do từ chối', 'error'); return; }
  showLoading();
  google.script.run
    .withSuccessHandler(res => {
      hideLoading();
      if (res.success) { showToast('Đã từ chối đơn ✅'); closeModal('modal-reject-leave'); loadLeaveTable(); }
      else showToast(res.error, 'error');
    })
    .handleRequest({ action: 'PROCESS_LEAVE_REQUEST', payload: { id, action: 'Rejected', reject_reason: reason } });
}

function loadLeaveBalance() {
  const val = document.getElementById('lv-balance-ns').value;
  if (!val) return;
  const [nsId] = val.split('|');
  const year = new Date().getFullYear();
  google.script.run
    .withSuccessHandler(res => {
      const area = document.getElementById('lv-balance-area');
      const balance = res.data !== null ? res.data : 12;
      const used    = 12 - balance;
      const pct     = Math.round((used / 12) * 100);
      area.innerHTML =
        '<div style="font-size:40px;font-weight:800;color:#3D35A8">' + balance + '</div>' +
        '<div style="color:var(--text-3);margin-bottom:10px">ngày phép còn lại năm ' + year + '</div>' +
        '<div style="background:#E0DDD8;border-radius:8px;height:10px;margin-bottom:8px">' +
          '<div style="height:100%;background:#3D35A8;border-radius:8px;width:' + pct + '%"></div>' +
        '</div>' +
        '<div style="font-size:13px;color:var(--text-3)">' + Math.max(0,used) + '/12 ngày đã dùng</div>';
    })
    .handleRequest({ action: 'GET_LEAVE_BALANCE', payload: { nsId, year } });
}

function esc(str) {
  if (!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

initLeave();
</script>`;
}


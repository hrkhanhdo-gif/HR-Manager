<script>
// ──────── PAYROLL JS ────────
let _prData = [];
let _prNsList = [];

function initPayroll() {
  google.script.run.withSuccessHandler(res => {
    _prNsList = res.success ? res.data.filter(n => n.Trang_Thai !== 'Đã nghỉ') : [];
    const sel = document.getElementById('cp-ns');
    _prNsList.forEach(ns => {
      sel.appendChild(new Option(
        ns.Ho_Ten + ' — ' + (ns.Bo_Phan || ''),
        ns.ID_NhanSu + '|' + ns.Ho_Ten + '|' + (ns.Bo_Phan || '')
      ));
    });
    document.getElementById('cp-period').value = getCurrentMonthPeriod();
    loadPayrollTable();
  }).handleRequest({ action: 'GET_NHAN_SU_LIST', payload: {} });
}

function getCurrentMonthPeriod() {
  const now = new Date();
  const m = String(now.getMonth() + 1).padStart(2, '0');
  return m + '/' + now.getFullYear();
}

function loadPayrollTable() {
  const period = document.getElementById('pr-period-filter').value;
  const status = document.getElementById('pr-status-filter').value;
  showLoading();
  google.script.run
    .withSuccessHandler(res => {
      hideLoading();
      if (!res.success) { showToast(res.error, 'error'); return; }
      _prData = res.data;
      renderPayrollTable(status);
      updatePayrollCards();
    })
    .handleRequest({ action: 'GET_PAYROLL_LIST', payload: { period, status: status || undefined } });
}

function updatePayrollCards() {
  const fmt = n => (n||0).toLocaleString('vi-VN') + ' đ';
  const totalGross = _prData.reduce((s, r) => s + (parseFloat(r.Gross_Salary)||0), 0);
  const totalNet   = _prData.reduce((s, r) => s + (parseFloat(r.Net_Salary)||0), 0);
  const totalEr    = _prData.reduce((s, r) => s + (parseFloat(r.BHXH_Employer)||0), 0);
  const approved   = _prData.filter(r => r.Status === 'Approved' || r.Status === 'Paid').length;

  document.getElementById('pr-total-gross').textContent = fmt(totalGross);
  document.getElementById('pr-total-net').textContent   = fmt(totalNet);
  document.getElementById('pr-total-cost').textContent  = fmt(totalGross + totalEr);
  document.getElementById('pr-count').textContent = _prData.length + ' / ' + approved + ' duyệt';
}

function renderPayrollTable(statusFilter) {
  let data = statusFilter ? _prData.filter(r => r.Status === statusFilter) : _prData;
  const tbody = document.getElementById('pr-tbody');
  const tfoot = document.getElementById('pr-tfoot');

  if (data.length === 0) {
    tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;color:var(--text-3);padding:40px">Không có dữ liệu phiếu lương</td></tr>';
    tfoot.innerHTML = '';
    return;
  }

  const fmt = n => (parseFloat(n)||0).toLocaleString('vi-VN');
  const statusMap = {
    Draft:    ['#888','#F4F4F2','Nháp'],
    Approved: ['#BA7517','#FAEEDA','Đã duyệt'],
    Paid:     ['#1D9E75','#E1F5EE','Đã trả']
  };

  tbody.innerHTML = data.map(r => {
    const [sc, bg, lbl] = statusMap[r.Status] || ['#888','#eee',r.Status];
    return '<tr>' +
      '<td><span style="font-weight:600">' + esc(r.Ho_Ten) + '</span></td>' +
      '<td style="color:var(--text-3)">' + esc(r.Bo_Phan||'') + '</td>' +
      '<td style="text-align:right">' + fmt(r.Basic_Salary) + '</td>' +
      '<td style="text-align:right;font-weight:600">' + fmt(r.Gross_Salary) + '</td>' +
      '<td style="text-align:right;color:#C0392B">-' + fmt(r.Total_Insurance) + '</td>' +

/**
 * Tính thuế TNCN theo biểu lũy tiến VN (7 bậc)
 * @param {number} taxableIncome - Thu nhập chịu thuế (sau giảm trừ)
 * @returns {number} Số tiền thuế
 */
function calcPIT(taxableIncome) {
  if (taxableIncome <= 0) return 0;
  const brackets = [
    { limit: 5000000,  rate: 0.05 },
    { limit: 10000000, rate: 0.10 },
    { limit: 18000000, rate: 0.15 },
    { limit: 32000000, rate: 0.20 },
    { limit: 52000000, rate: 0.25 },
    { limit: 80000000, rate: 0.30 },
    { limit: Infinity,  rate: 0.35 },
  ];
  let tax = 0;
  let prev = 0;
  for (const b of brackets) {
    if (taxableIncome <= prev) break;
    const slice = Math.min(taxableIncome - prev, b.limit - prev);
    tax += slice * b.rate;
    prev = b.limit;
  }
  return Math.round(tax);
}

/**
 * Tính toàn bộ bảng lương cho một nhân sự trong một kỳ
 * @param {Object} input
 *   - basic_salary: Lương cơ bản
 *   - allowance: Phụ cấp (không tính BHXH)
 *   - bonus: Thưởng (không tính BHXH)
 *   - work_days: Ngày công thực tế
 *   - standard_days: Ngày công chuẩn tháng (mặc định 26)
 *   - dependents: Số người phụ thuộc (mặc định 0)
 * @returns {Object} Kết quả tính lương đầy đủ
 */
function calcSalary(input) {
  const BHXH_EE  = 0.08;
  const BHYT_EE  = 0.015;
  const BHTN_EE  = 0.01;
  const BHXH_ER  = 0.175;
  const PERSONAL_DEDUCTION   = 11000000;
  const DEPENDENT_DEDUCTION  = 4400000;

  const basic        = parseFloat(input.basic_salary) || 0;
  const allowance    = parseFloat(input.allowance) || 0;
  const bonus        = parseFloat(input.bonus) || 0;
  const workDays     = parseFloat(input.work_days) || 26;
  const standardDays = parseFloat(input.standard_days) || 26;
  const dependents   = parseInt(input.dependents) || 0;

  // Lương theo ngày công thực tế
  const salaryRatio  = standardDays > 0 ? workDays / standardDays : 1;
  const actualBasic  = Math.round(basic * salaryRatio);

  // BHXH tính trên lương cơ bản (không gồm phụ cấp, bonus)
  const bhxh_ee  = Math.round(basic * BHXH_EE  * salaryRatio);
  const bhyt_ee  = Math.round(basic * BHYT_EE  * salaryRatio);
  const bhtn_ee  = Math.round(basic * BHTN_EE  * salaryRatio);
  const totalIns = bhxh_ee + bhyt_ee + bhtn_ee;

  // Gross = lương thực tế + phụ cấp + bonus (tỉ lệ ngày công)
  const gross = Math.round(actualBasic + allowance * salaryRatio + bonus * salaryRatio);

  // Thu nhập chịu thuế = Gross - Bảo hiểm - Giảm trừ bản thân - Giảm trừ người phụ thuộc
  const totalDeduction = PERSONAL_DEDUCTION + dependents * DEPENDENT_DEDUCTION;
  const taxableIncome  = Math.max(0, gross - totalIns - totalDeduction);

  const pit     = calcPIT(taxableIncome);
  const net     = gross - totalIns - pit;
  const bhxh_er = Math.round(basic * BHXH_ER * salaryRatio);

  return {
    basic_salary:    basic,
    actual_basic:    actualBasic,
    allowance:       Math.round(allowance * salaryRatio),
    bonus:           Math.round(bonus * salaryRatio),
    work_days:       workDays,
    standard_days:   standardDays,
    gross_salary:    gross,
    bhxh_employee:   bhxh_ee,
    bhyt_employee:   bhyt_ee,
    bhtn_employee:   bhtn_ee,
    total_insurance: totalIns,
    taxable_income:  taxableIncome,
    tax_pit:         pit,
    net_salary:      net,
    bhxh_employer:   bhxh_er,
  };
}

/**
 * Tạo bản ghi payroll cho một nhân sự
 */
function createPayroll(data, user) {
  if (!data.id_nhan_su || !data.period || !data.basic_salary) {
    return { success: false, error: 'Thiếu ID nhân sự, kỳ lương hoặc lương cơ bản' };
  }

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('PAYROLL') || setupPayrollSheet();

  // Kiểm tra trùng lặp (cùng nhân sự + cùng kỳ)
  const existing = sheet.getDataRange().getValues().slice(1);
  const dup = existing.find(r => r[1] === data.id_nhan_su && r[4] === data.period);
  if (dup) {
    return { success: false, error: `Đã có bảng lương kỳ ${data.period} cho nhân sự này` };
  }

  const calc = calcSalary(data);
  const id   = generateId('PR');

  sheet.appendRow([
    id, data.id_nhan_su, data.ho_ten || '', data.bo_phan || '', data.period,
    calc.basic_salary, parseFloat(data.allowance) || 0, parseFloat(data.bonus) || 0,
    calc.work_days, calc.standard_days,
    calc.gross_salary, calc.bhxh_employee, calc.bhyt_employee, calc.bhtn_employee,
    calc.total_insurance, calc.taxable_income, calc.tax_pit, calc.net_salary,
    calc.bhxh_employer,
    'Draft', data.note || '', new Date(), user.email
  ]);

  writeAuditLog('CREATE', 'PAYROLL', id, '', '', data.id_nhan_su,
    `Tạo payroll ${data.period} — Net: ${formatVnd(calc.net_salary)}`);

  return { success: true, id, calc };
}

/**
 * Tạo bảng lương hàng loạt cho tất cả nhân sự đang active trong kỳ
 */
function runBatchPayroll(period, user) {
  if (!period) return { success: false, error: 'Thiếu kỳ lương' };

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const nsSheet = ss.getSheetByName('NHAN_SU');
  if (!nsSheet) return { success: false, error: 'Sheet NHAN_SU không tồn tại' };

  const nsData = nsSheet.getDataRange().getValues().slice(1)
    .filter(r => r[0] && r[8] !== 'Đã nghỉ');

  // Lấy ngày công từ bảng chấm công nếu có
  const attData = getAttendanceMap(period);

  let created = 0;
  let skipped = 0;
  const errors = [];

  nsData.forEach(row => {
    const nsId   = row[0];
    const hoTen  = row[1];
    const boPhan = row[2];
    // Lương cơ bản lấy từ cột 13 (Link_HoSo placeholder — cần thêm cột Luong_CB vào NHAN_SU)
    // Fallback: dùng 0, HR nhập thủ công sau
    const workDays = attData[nsId] || 26;

    const res = createPayroll({
      id_nhan_su: nsId, ho_ten: hoTen, bo_phan: boPhan,
      period, basic_salary: row[12] || 0, // cột M = lương nếu đã thêm
      allowance: 0, bonus: 0,
      work_days: workDays, standard_days: 26, dependents: 0
    }, user);

    if (res.success) created++;
    else if (res.error && res.error.includes('Đã có')) skipped++;
    else errors.push(`${hoTen}: ${res.error}`);

    Utilities.sleep(100); // Tránh vượt quota
  });

  return { success: true, created, skipped, errors };
}

/**
 * Cập nhật trạng thái payroll (Draft → Approved → Paid)
 */
function updatePayrollStatus(data, user) {
  if (!data.id || !data.status) return { success: false, error: 'Thiếu ID hoặc trạng thái' };

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('PAYROLL');
  if (!sheet) return { success: false, error: 'Sheet PAYROLL không tồn tại' };

  const allData = sheet.getDataRange().getValues();
  for (let i = 1; i < allData.length; i++) {
    if (allData[i][0] === data.id) {
      const oldStatus = allData[i][19];
      sheet.getRange(i + 1, 20).setValue(data.status);

      const colors = { Draft: '#FFFFFF', Approved: '#FAEEDA', Paid: '#E1F5EE' };
      sheet.getRange(i + 1, 1, 1, allData[0].length)
        .setBackground(colors[data.status] || '#FFFFFF');

      writeAuditLog('UPDATE', 'PAYROLL', data.id, 'Status', oldStatus, data.status, '');
      return { success: true, message: `Đã cập nhật trạng thái → ${data.status}` };
    }
  }
  return { success: false, error: 'Không tìm thấy bản ghi payroll' };
}

/**
 * Cập nhật một trường payroll (basic_salary, allowance, bonus, work_days)
 * → Tự tính lại toàn bộ
 */
function updatePayrollRecord(data, user) {
  if (!data.id) return { success: false, error: 'Thiếu ID payroll' };

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('PAYROLL');
  if (!sheet) return { success: false, error: 'Sheet PAYROLL không tồn tại' };

  const allData = sheet.getDataRange().getValues();
  for (let i = 1; i < allData.length; i++) {
    if (allData[i][0] !== data.id) continue;

    const row = allData[i];
    const input = {
      basic_salary:  data.basic_salary  !== undefined ? data.basic_salary  : row[5],
      allowance:     data.allowance     !== undefined ? data.allowance     : row[6],
      bonus:         data.bonus         !== undefined ? data.bonus         : row[7],
      work_days:     data.work_days     !== undefined ? data.work_days     : row[8],
      standard_days: data.standard_days !== undefined ? data.standard_days : row[9],
      dependents:    data.dependents    !== undefined ? data.dependents    : 0,
    };

    const calc = calcSalary(input);
    const updateRow = [
      row[0], row[1], row[2], row[3], row[4],
      calc.basic_salary, input.allowance, input.bonus, calc.work_days, calc.standard_days,
      calc.gross_salary, calc.bhxh_employee, calc.bhyt_employee, calc.bhtn_employee,
      calc.total_insurance, calc.taxable_income, calc.tax_pit, calc.net_salary,
      calc.bhxh_employer,
      row[19], data.note || row[20], row[21], user.email
    ];

    sheet.getRange(i + 1, 1, 1, updateRow.length).setValues([updateRow]);
    writeAuditLog('UPDATE', 'PAYROLL', data.id, 'recalculated', '', '', user.email);
    return { success: true, calc };
  }
  return { success: false, error: 'Không tìm thấy bản ghi payroll' };
}

/**
 * Lấy danh sách payroll (lọc theo period / nsId / status)
 */
function getPayrollList(options) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('PAYROLL');
  if (!sheet) return [];

  const data = sheet.getDataRange().getValues();
  if (data.length < 2) return [];

  const headers = data[0].map(h => h.toString());
  let rows = data.slice(1).filter(r => r[0] !== '').map(row => {
    const obj = {};
    headers.forEach((h, i) => { obj[h] = row[i] instanceof Date ? row[i].toISOString() : row[i]; });
    return obj;
  });

  if (options) {
    if (options.period) rows = rows.filter(r => r['Period'] === options.period);
    if (options.nsId)   rows = rows.filter(r => r['ID_NhanSu'] === options.nsId);
    if (options.status) rows = rows.filter(r => r['Status'] === options.status);
  }
  return rows;
}

/**
 * Gửi payslip qua email cho nhân sự
 */
function sendPayslip(payrollId, user) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('PAYROLL');
  if (!sheet) return { success: false, error: 'Sheet PAYROLL không tồn tại' };

  const allData = sheet.getDataRange().getValues();
  const headerRow = allData[0].map(h => h.toString());
  const row = allData.slice(1).find(r => r[0] === payrollId);
  if (!row) return { success: false, error: 'Không tìm thấy bản ghi payroll' };

  // Lấy email nhân sự từ NHAN_SU
  const nsSheet = ss.getSheetByName('NHAN_SU');
  let nsEmail = '';
  if (nsSheet) {
    const nsData = nsSheet.getDataRange().getValues().slice(1);
    const nsRow = nsData.find(r => r[0] === row[1]);
    if (nsRow) nsEmail = nsRow[7];
  }

  if (!nsEmail) return { success: false, error: 'Không tìm thấy email nhân sự' };

  const period  = row[4];
  const hoTen   = row[2];
  const subject = `💰 Phiếu lương tháng ${period} — ${hoTen}`;

  const body = buildPayslipBody(row, headerRow);

  try {
    MailApp.sendEmail({
      to: nsEmail,
      subject,
      htmlBody: body,
    });
    writeAuditLog('CREATE', 'PAYROLL', payrollId, 'SendPayslip', '', nsEmail,
      `Gửi payslip ${period}`);
    return { success: true, message: `Đã gửi payslip đến ${nsEmail}` };
  } catch (e) {
    return { success: false, error: 'Lỗi gửi email: ' + e.message };
  }
}


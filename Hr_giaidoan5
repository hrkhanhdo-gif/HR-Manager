        ';padding:2px 8px;border-radius:10px;font-size:12px">' + esc(r.Leave_Type) + '</span></td>' +
      '<td>' + fmtDate(r.From_Date) + '</td>' +
      '<td>' + fmtDate(r.To_Date) + '</td>' +
      '<td style="text-align:center;font-weight:700">' + (r.Days||'—') + '</td>' +

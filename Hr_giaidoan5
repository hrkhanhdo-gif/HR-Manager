function renderLeaveTable(data) {
  const tbody = document.getElementById('lv-tbody');
  if (data.length === 0) {
    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--text-3);padding:40px">Không có đơn nghỉ phép</td></tr>';
    return;
  }
  const statusMap = {
    Pending:   ['#BA7517','#FAEEDA','⏳ Chờ duyệt'],
    Approved:  ['#1D9E75','#E1F5EE','✅ Đã duyệt'],
    Rejected:  ['#C0392B','#FCEBEB','❌ Từ chối'],
    Cancelled: ['#888','#F4F4F2','🚫 Huỷ'],
  };
  const fmtDate = iso => iso ? new Date(iso).toLocaleDateString('vi-VN') : '—';

  tbody.innerHTML = data.map(r => {
    const [sc, bg, lbl] = statusMap[r.Status] || ['#888','#eee',r.Status];
    const typeColors = {
      'Nghỉ phép năm': '#EEEDFE', 'Nghỉ bệnh': '#FAEEDA',
      'Nghỉ không lương': '#FCEBEB', 'Nghỉ thai sản': '#E6F1FB',
    };

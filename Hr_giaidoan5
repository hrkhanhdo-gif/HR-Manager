/**
 * Setup sheet PAYROLL
 */
function setupPayrollSheet() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheetName = 'PAYROLL';
  let sheet = ss.getSheetByName(sheetName);
  if (!sheet) {
    sheet = ss.insertSheet(sheetName);
    const headers = [
      'ID_Payroll', 'ID_NhanSu', 'Ho_Ten', 'Bo_Phan', 'Period',
      'Basic_Salary', 'Allowance', 'Bonus', 'Work_Days', 'Standard_Days',
      'Gross_Salary', 'BHXH_Employee', 'BHYT_Employee', 'BHTN_Employee',
      'Total_Insurance', 'Taxable_Income', 'Tax_PIT', 'Net_Salary',
      'BHXH_Employer', 'Status', 'Note', 'Created_At', 'Created_By'
    ];
    sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
    sheet.getRange(1, 1, 1, headers.length)
      .setBackground('#085041')
      .setFontColor('#FFFFFF')
      .setFontWeight('bold');
    sheet.setFrozenRows(1);
    sheet.setFrozenColumns(2);

    const statusRule = SpreadsheetApp.newDataValidation()
      .requireValueInList(['Draft', 'Approved', 'Paid'], true).build();
    sheet.getRange('T2:T2000').setDataValidation(statusRule);

    // Format số tiền
    const moneyFormat = '#,##0';
    [6,7,8,11,12,13,14,15,16,17,18,19].forEach(col => {
      sheet.getRange(2, col, 2000, 1).setNumberFormat(moneyFormat);
    });

    const colWidths = [160,140,160,120,90,140,120,110,90,100,140,130,130,130,130,140,110,140,130,100,200,140,160];
    colWidths.forEach((w, i) => sheet.setColumnWidth(i + 1, w));
    Logger.log('✅ Đã tạo sheet PAYROLL');
  }
  return sheet;
}


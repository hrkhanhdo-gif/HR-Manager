function updateLeaveCards(data) {
  document.getElementById('lv-pending').textContent  = data.filter(r => r.Status === 'Pending').length;
  document.getElementById('lv-approved').textContent = data.filter(r => r.Status === 'Approved').length;
  document.getElementById('lv-rejected').textContent = data.filter(r => r.Status === 'Rejected').length;
  const totalDays = data.filter(r => r.Status === 'Approved')
    .reduce((s, r) => s + (parseFloat(r.Days)||0), 0);
  document.getElementById('lv-total-days').textContent = totalDays + ' ngày';

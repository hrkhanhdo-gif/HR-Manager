/**
 * Tạo đơn xin nghỉ phép
 */
function createLeaveRequest(data, user) {
  if (!data.id_nhan_su || !data.leave_type || !data.from_date || !data.to_date) {
    return { success: false, error: 'Thiếu thông tin bắt buộc (nhân sự, loại nghỉ, ngày)' };
  }

  const fromDate = new Date(data.from_date);
  const toDate   = new Date(data.to_date);
  if (toDate < fromDate) {
    return { success: false, error: 'Ngày kết thúc phải sau ngày bắt đầu' };
  }

  // Tính số ngày (không tính thứ 7, CN)
  const days = countWorkDays(fromDate, toDate);
  if (days <= 0) return { success: false, error: 'Khoảng thời gian nghỉ không hợp lệ' };

  // Kiểm tra số ngày phép còn lại nếu là nghỉ phép năm
  if (data.leave_type === 'Nghỉ phép năm') {
    const balance = getLeaveBalance(data.id_nhan_su, new Date().getFullYear());
    if (balance !== null && balance < days) {
      return { success: false, error: `Không đủ ngày phép. Còn lại: ${balance} ngày, yêu cầu: ${days} ngày` };
    }
  }

  const ss    = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('LEAVE_REQUESTS') || setupLeaveRequestsSheet();
  const id    = generateId('LV');

  const approverEmail = data.approver || CONFIG.NOTIFY.EMAIL_ALERT;

  sheet.appendRow([
    id, data.id_nhan_su, data.ho_ten || '', data.bo_phan || '',
    data.leave_type, fromDate, toDate, days,
    data.reason || '', approverEmail,
    'Pending', '', '', new Date(), user.email
  ]);

  // Gửi email thông báo đến người duyệt
  sendLeaveApprovalRequest(id, data, days, approverEmail, user);

  writeAuditLog('CREATE', 'LEAVE_REQUESTS', id, '', '', data.id_nhan_su,
    `Xin nghỉ ${data.leave_type}: ${days} ngày`);

  return { success: true, id, days };
}

/**
 * Phê duyệt / Từ chối đơn nghỉ phép
 */
function processLeaveRequest(data, user) {
  if (!data.id || !data.action) return { success: false, error: 'Thiếu ID hoặc action' };
  if (!['Approved','Rejected','Cancelled'].includes(data.action)) {
    return { success: false, error: 'Action không hợp lệ' };
  }

  const ss    = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('LEAVE_REQUESTS');
  if (!sheet) return { success: false, error: 'Sheet LEAVE_REQUESTS không tồn tại' };

  const allData = sheet.getDataRange().getValues();
  for (let i = 1; i < allData.length; i++) {
    if (allData[i][0] !== data.id) continue;

    const oldStatus  = allData[i][10];
    const nsId       = allData[i][1];
    const leaveType  = allData[i][4];
    const days       = parseFloat(allData[i][7]);
    const year       = new Date(allData[i][5]).getFullYear();

    if (oldStatus !== 'Pending') {
      return { success: false, error: `Đơn đã ở trạng thái ${oldStatus}, không thể thay đổi` };
    }

    sheet.getRange(i + 1, 11).setValue(data.action);
    sheet.getRange(i + 1, 12).setValue(new Date());
    if (data.reject_reason) sheet.getRange(i + 1, 13).setValue(data.reject_reason);

    const colors = { Approved: '#E1F5EE', Rejected: '#FCEBEB', Cancelled: '#F4F4F2' };
    sheet.getRange(i + 1, 1, 1, allData[0].length)
      .setBackground(colors[data.action] || '#FFFFFF');

    // Trừ ngày phép nếu Approved
    if (data.action === 'Approved' && leaveType === 'Nghỉ phép năm') {
      deductLeaveBalance(nsId, allData[i][2], days, year, user.email);
    }

    // Gửi email kết quả cho nhân sự
    sendLeaveResultNotification(allData[i], data.action, data.reject_reason);

    writeAuditLog('UPDATE', 'LEAVE_REQUESTS', data.id, 'Status',
      oldStatus, data.action, user.email);
    return { success: true, message: `Đã ${data.action === 'Approved' ? 'duyệt' : 'từ chối'} đơn nghỉ phép` };
  }
  return { success: false, error: 'Không tìm thấy đơn nghỉ' };
}

/**
 * Lấy danh sách đơn nghỉ phép
 */
function getLeaveList(options) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('LEAVE_REQUESTS');
  if (!sheet) return [];

  const data = sheet.getDataRange().getValues();
  if (data.length < 2) return [];

  const headers = data[0].map(h => h.toString());
  let rows = data.slice(1).filter(r => r[0] !== '').map(row => {
    const obj = {};
    headers.forEach((h, i) => { obj[h] = row[i] instanceof Date ? row[i].toISOString() : row[i]; });
    return obj;
  });

  if (options) {
    if (options.nsId)   rows = rows.filter(r => r['ID_NhanSu'] === options.nsId);
    if (options.status) rows = rows.filter(r => r['Status'] === options.status);
    if (options.month) {
      rows = rows.filter(r => {
        const d = new Date(r['From_Date']);
        return d.getMonth() === options.month - 1;
      });
    }
  }
  return rows.sort((a, b) => new Date(b['Created_At']) - new Date(a['Created_At']));
}

/**
 * Tính số ngày làm việc giữa 2 ngày (bỏ qua T7, CN)
 */
function countWorkDays(fromDate, toDate) {
  let count = 0;
  const d = new Date(fromDate);
  while (d <= toDate) {
    const dow = d.getDay();
    if (dow !== 0 && dow !== 6) count++;
    d.setDate(d.getDate() + 1);
  }
  return count;
}

/**
 * Lấy số ngày phép còn lại của nhân sự
 */
function getLeaveBalance(nsId, year) {
  try {
    const ss    = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('LEAVE_BALANCE');
    if (!sheet) return null;

    const data = sheet.getDataRange().getValues().slice(1);
    const row  = data.find(r => r[0] === nsId && r[2] === year);
    return row ? parseFloat(row[5]) : 12; // Mặc định 12 ngày/năm nếu chưa có record
  } catch (e) {
    return null;
  }
}

/**
 * Trừ ngày phép khi đơn được duyệt
 */
function deductLeaveBalance(nsId, hoTen, days, year, byEmail) {
  try {
    const ss    = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('LEAVE_BALANCE') || setupLeaveBalanceSheet();
    const data  = sheet.getDataRange().getValues();

    for (let i = 1; i < data.length; i++) {
      if (data[i][0] === nsId && data[i][2] === year) {
        const used      = parseFloat(data[i][4]) || 0;
        const entitle   = parseFloat(data[i][3]) || 12;
        const newUsed   = used + days;
        const remaining = Math.max(0, entitle - newUsed);
        sheet.getRange(i + 1, 5).setValue(newUsed);
        sheet.getRange(i + 1, 6).setValue(remaining);
        sheet.getRange(i + 1, 9).setValue(new Date());
        return;
      }
    }
    // Chưa có record → tạo mới
    sheet.appendRow([
      nsId, hoTen, year, 12,
      days, Math.max(0, 12 - days), 0, 0, new Date()
    ]);
  } catch (e) {
    Logger.log('deductLeaveBalance error: ' + e.message);
  }
}


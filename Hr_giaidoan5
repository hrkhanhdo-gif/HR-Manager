/**
 * Báo cáo HR tháng — tổng hợp headcount, tuyển dụng, nghỉ việc, chi phí lương
 */
function buildMonthlyHrReport(period) {
  const p = period || getCurrentPeriod();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const report = { period: p, generated_at: new Date().toISOString() };

  // ── Headcount ──
  try {
    const nsData = ss.getSheetByName('NHAN_SU')?.getDataRange().getValues().slice(1) || [];
    const active  = nsData.filter(r => r[0] && r[8] !== 'Đã nghỉ');
    const left    = nsData.filter(r => r[8] === 'Đã nghỉ');

    report.headcount = {
      total_active: active.length,
      chinh_thuc:   active.filter(r => r[8] === 'Chính thức').length,
      thu_viec:     active.filter(r => r[8] === 'Thử việc').length,
      thuc_tap:     active.filter(r => r[8] === 'Thực tập').length,
      da_nghi:      left.length,
    };

    // By department
    const byDept = {};
    active.forEach(r => {
      const d = r[2] || 'Chưa phân bộ phận';
      byDept[d] = (byDept[d] || 0) + 1;
    });
    report.headcount.by_department = byDept;
  } catch (e) {}

  // ── Tuyển dụng trong kỳ ──
  try {
    const uvData = ss.getSheetByName('UNG_VIEN')?.getDataRange().getValues().slice(1) || [];
    report.recruitment = {
      total_cv:       uvData.filter(r => r[0]).length,
      dang_xet:       uvData.filter(r => r[5] === 'Đang xét').length,
      da_offer:       uvData.filter(r => r[5] === 'Chính thức').length,
      tu_choi:        uvData.filter(r => r[5] === 'Từ chối').length,
    };
  } catch (e) {}

  // ── Nghỉ phép ──
  try {
    const lvData = getLeaveList({ status: 'Approved' });
    report.leave = {
      total_requests: lvData.length,
      total_days:     lvData.reduce((s, r) => s + (parseFloat(r['Days']) || 0), 0),
      by_type: lvData.reduce((acc, r) => {
        const t = r['Leave_Type'] || 'Khác';
        acc[t] = (acc[t] || 0) + (parseFloat(r['Days']) || 0);
        return acc;
      }, {}),
    };
  } catch (e) {}

  // ── Chi phí lương ──
  try {
    const payData = getPayrollList({ period: p });
    const totalGross = payData.reduce((s, r) => s + (parseFloat(r['Gross_Salary']) || 0), 0);
    const totalNet   = payData.reduce((s, r) => s + (parseFloat(r['Net_Salary']) || 0), 0);
    const totalEr    = payData.reduce((s, r) => s + (parseFloat(r['BHXH_Employer']) || 0), 0);
    report.payroll = {
      record_count:    payData.length,
      total_gross:     totalGross,
      total_net:       totalNet,
      total_er_cost:   totalEr,
      total_cost:      totalGross + totalEr,
      avg_net:         payData.length > 0 ? Math.round(totalNet / payData.length) : 0,
    };
  } catch (e) {}

  // ── KPI tổng quan ──
  try {
    const kpiData = getKpiList({ period: p });
    const scored  = kpiData.filter(k => k['Score_Pct'] !== '' && k['Score_Pct'] !== null);
    report.kpi = {
      total_kpis:  kpiData.length,
      scored_kpis: scored.length,
      avg_score:   scored.length > 0
        ? Math.round(scored.reduce((s, k) => s + parseFloat(k['Score_Pct'] || 0), 0) / scored.length)
        : 0,
      above_100:   scored.filter(k => parseFloat(k['Score_Pct']) >= 100).length,
      below_80:    scored.filter(k => parseFloat(k['Score_Pct']) < 80).length,
    };
  } catch (e) {}

  return report;
}

/**
 * Báo cáo turnover — tỷ lệ nghỉ việc theo bộ phận
 */
function buildTurnoverReport(year) {
  const y = year || new Date().getFullYear();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const report = { year: y, generated_at: new Date().toISOString() };

  try {
    const auditData = ss.getSheetByName('AUDIT_LOG')
      ?.getDataRange().getValues().slice(1) || [];

    // Lọc các lần xóa mềm (đổi Trang_Thai → Đã nghỉ) trong năm y
    const leftEvents = auditData.filter(r =>
      r[3] === 'UPDATE' &&
      r[7] !== 'Đã nghỉ' &&
      r[8] === 'Đã nghỉ' &&
      r[0] instanceof Date &&
      r[0].getFullYear() === y
    );

    const nsData = ss.getSheetByName('NHAN_SU')
      ?.getDataRange().getValues().slice(1).filter(r => r[0]) || [];

    const activeCount  = nsData.filter(r => r[8] !== 'Đã nghỉ').length;
    const totalCount   = nsData.length;
    const turnoverRate = totalCount > 0
      ? ((leftEvents.length / totalCount) * 100).toFixed(1)
      : 0;

    // Turnover by department (dùng audit log ID để join về NHAN_SU)
    const nsMap = {};
    nsData.forEach(r => { nsMap[r[0]] = r[2] || 'Chưa rõ'; });

    const byDept = {};
    leftEvents.forEach(e => {
      const dept = nsMap[e[5]] || 'Chưa rõ';
      byDept[dept] = (byDept[dept] || 0) + 1;
    });

    // Monthly trend
    const byMonth = {};
    leftEvents.forEach(e => {
      if (!(e[0] instanceof Date)) return;
      const m = `T${e[0].getMonth() + 1}`;
      byMonth[m] = (byMonth[m] || 0) + 1;
    });

    report.summary = {
      total_employees:  totalCount,
      active_employees: activeCount,
      resigned_count:   leftEvents.length,
      turnover_rate_pct: parseFloat(turnoverRate),
    };
    report.by_department = byDept;
    report.monthly_trend = byMonth;
  } catch (e) {
    Logger.log('buildTurnoverReport error: ' + e.message);
  }

  return report;
}

/**
 * AI phân tích insights từ monthly report
 */
function aiPayrollInsights(period) {
  const apiKey = PropertiesService.getScriptProperties().getProperty('CLAUDE_API_KEY');
  if (!apiKey) return { success: false, error: 'Chưa cài API Key' };

  const report = buildMonthlyHrReport(period);

  const prompt = `Bạn là HR analyst chuyên nghiệp.
Phân tích dữ liệu HR tháng dưới đây và đưa ra 3–5 nhận xét ngắn gọn, actionable bằng tiếng Việt.

Dữ liệu:
${JSON.stringify(report, null, 2)}

Trả về JSON hợp lệ (không có text ngoài JSON):
{
  "insights": [
    { "icon": "emoji", "title": "Tiêu đề ngắn", "detail": "Mô tả chi tiết và gợi ý hành động" }
  ],
  "overall_health": "good | warning | critical",
  "summary": "1-2 câu tóm tắt tổng thể"
}`;

  try {
    const response = UrlFetchApp.fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': apiKey,
        'anthropic-version': '2023-06-01'
      },
      payload: JSON.stringify({
        model: 'claude-opus-4-5',
        max_tokens: 1200,
        messages: [{ role: 'user', content: prompt }]
      }),
      muteHttpExceptions: true
    });

    const result = JSON.parse(response.getContentText());
    if (result.error) throw new Error(result.error.message);

    const raw    = result.content[0].text.trim();
    const parsed = JSON.parse(raw.replace(/```json|```/g, '').trim());
    return { success: true, data: parsed };
  } catch (e) {
    return { success: false, error: 'AI lỗi: ' + e.message };
  }
}


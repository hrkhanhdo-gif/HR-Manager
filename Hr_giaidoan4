  google.script.run
    .withSuccessHandler(res => {
      hideLoading();
      if (res.success) {
        showToast('Đã cập nhật task ✅');
        loadOnboardingBoard();
      } else {
        showToast(res.error, 'error');
      }
    })
    .handleRequest({ action: 'UPDATE_ONBOARDING_TASK', payload: { id: taskId, status: newStatus } });
}

function loadProgress(nsId) {
  google.script.run
    .withSuccessHandler(res => {
      if (res.success) {
        const p = res.data;
        document.getElementById('onb-progress-pct').textContent = p.pct + '%';
        document.getElementById('onb-progress-bar').style.width = p.pct + '%';
        document.getElementById('onb-progress-label').textContent =
          'Tiến độ onboarding: ' + p.done + '/' + p.total + ' task hoàn thành';
        const counts = { Done: 0, 'In Progress': 0, Pending: 0, Skip: 0 };
        _onbTasks.forEach(t => { if (counts[t.Status] !== undefined) counts[t.Status]++; });
        document.getElementById('onb-done-count').textContent = counts.Done;
        document.getElementById('onb-inprogress-count').textContent = counts['In Progress'];
        document.getElementById('onb-pending-count').textContent = counts.Pending;
        document.getElementById('onb-skip-count').textContent = counts.Skip;
      }
    })
    .handleRequest({ action: 'GET_ONBOARDING_PROGRESS', payload: { nsId } });
}

function openAddTaskModal() {

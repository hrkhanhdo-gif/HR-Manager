/**
 * Trigger hàng ngày: kiểm tra nhân sự thử việc sắp đến hạn đánh giá (>= 55 ngày)
 * Setup trigger: Time-driven > Day timer > 8am–9am
 */
function runProbationChecker() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('NHAN_SU');
  if (!sheet) return;

  const data = sheet.getDataRange().getValues();
  const today = new Date();
  const alerts = [];

  data.slice(1).forEach((row, i) => {
    if (row[8] !== 'Thử việc') return; // Chỉ check Thử việc
    if (!row[4]) return; // Phải có ngày vào

    const ngayVao = new Date(row[4]);
    const diffDays = Math.floor((today - ngayVao) / (1000 * 60 * 60 * 24));

    // Nhắc khi còn 5 ngày, đúng ngày 60, và quá hạn
    if (diffDays === 55 || diffDays === 58 || diffDays === 60 || diffDays === 65) {
      alerts.push({
        name: row[1],
        email: row[7],
        ngayVao: ngayVao,
        diffDays,
        id: row[0]
      });
    }
  });

  if (alerts.length === 0) return;

  const adminEmail = CONFIG.NOTIFY.EMAIL_ALERT;
  let body = `📋 NHẮC NHỞ: Các nhân sự thử việc cần đánh giá\n\n`;
  alerts.forEach(a => {
    body += `• ${a.name} (${a.id}) — Ngày ${a.diffDays}/60 thử việc\n`;
    body += `  Ngày vào: ${Utilities.formatDate(a.ngayVao, 'Asia/Ho_Chi_Minh', 'dd/MM/yyyy')}\n\n`;
  });
  body += `\nVui lòng hoàn thành đánh giá kết thúc thử việc đúng hạn.`;

  try {
    MailApp.sendEmail(adminEmail,
      `⚠️ [HR] ${alerts.length} nhân sự thử việc sắp đến hạn đánh giá`, body);
  } catch (e) {
    Logger.log('⚠️ Probation checker email error: ' + e.message);
  }

  writeAuditLog('CREATE', 'SYSTEM', 'PROBATION_CHECK', '', '', alerts.length,
    `Nhắc ${alerts.length} nhân sự sắp hết thử việc`);
}


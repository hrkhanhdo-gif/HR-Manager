      <div class="metric-label">Dưới 80%</div>
      <div class="metric-value" id="kpi-below-80" style="color:#C0392B">—</div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:2fr 1fr;gap:16px">
    <!-- Bảng KPI -->
    <div class="panel">
      <div class="panel-header" style="display:flex;justify-content:space-between;align-items:center">
        <span>Danh sách KPI</span>
        <div style="display:flex;gap:8px">
          <select id="kpi-ns-filter" class="form-control" style="width:200px" onchange="loadKpiTable()">
            <option value="">Tất cả nhân sự</option>
          </select>
          <input id="kpi-search" class="form-control" placeholder="🔍 Tìm KPI..."
                 style="width:160px" oninput="filterKpiTable()">
        </div>
      </div>
      <div class="panel-body" style="padding:0;overflow-x:auto">
        <table class="data-table" id="kpi-table">
          <thead>
            <tr>
              <th>Nhân sự</th><th>KPI</th><th>Target</th>
              <th>Actual</th><th>%</th><th>Weight</th><th>Thao tác</th>
            </tr>
          </thead>
          <tbody id="kpi-tbody">
            <tr><td colspan="7" style="text-align:center;color:var(--text-3);padding:32px">
              Chọn kỳ để xem KPI</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- AI Suggest + Individual Score -->
    <div style="display:flex;flex-direction:column;gap:14px">
      <div class="panel">
        <div class="panel-header">🤖 AI Gợi ý KPI</div>
        <div class="panel-body">
          <div class="form-group">
            <label>Chức vụ</label>
            <input id="ai-chuc-vu" class="form-control" placeholder="VD: Kỹ sư phần mềm">
          </div>
          <div class="form-group">
            <label>Bộ phận</label>
            <input id="ai-bo-phan" class="form-control" placeholder="VD: Engineering">
          </div>
          <button class="btn btn-primary" style="width:100%;margin-top:4px"
                  onclick="runAiSuggestKpi()">✨ Gợi ý KPI</button>
          <div id="ai-kpi-result" style="margin-top:14px;display:none"></div>
        </div>
      </div>

      <div class="panel">
        <div class="panel-header">🏆 Điểm KPI cá nhân</div>
        <div class="panel-body">
          <select id="score-ns-sel" class="form-control" style="margin-bottom:10px"
                  onchange="loadIndividualScore()">
            <option value="">-- Chọn nhân sự --</option>
          </select>
          <div id="individual-score-area" style="text-align:center;color:var(--text-3);padding:16px">
            Chọn nhân sự để xem điểm
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal Tạo KPI -->
  <div id="modal-kpi" class="modal" style="display:none">
    <div class="modal-content" style="max-width:500px">
      <div class="modal-header">
        <h3 id="kpi-modal-title">Tạo KPI mới</h3>
        <button class="btn-close" onclick="closeModal('modal-kpi')">×</button>
      </div>
      <div class="modal-body" style="display:flex;flex-direction:column;gap:14px">
        <div class="form-group">
          <label>Nhân sự *</label>
          <select id="kpi-ns-sel" class="form-control"></select>
        </div>
        <div class="form-group">
          <label>Tên KPI *</label>
          <input id="kpi-name" class="form-control" placeholder="VD: Doanh thu tháng">
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group">
            <label>Kỳ đánh giá</label>
            <input id="kpi-period" class="form-control" placeholder="Q2/2026">
          </div>
          <div class="form-group">
            <label>Mục tiêu (Target) *</label>
            <input id="kpi-target" type="number" class="form-control" placeholder="100">
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group">
            <label>Trọng số (0–1) *</label>
            <input id="kpi-weight" type="number" step="0.05" min="0" max="1"
                   class="form-control" placeholder="0.3">
          </div>
          <div class="form-group">
            <label>Kết quả thực tế</label>
            <input id="kpi-actual" type="number" class="form-control" placeholder="Để trống">
          </div>
        </div>
        <div class="form-group">
          <label>Ghi chú</label>
          <textarea id="kpi-note" class="form-control" rows="2"
                    placeholder="Mô tả cách đo lường..."></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-ghost" onclick="closeModal('modal-kpi')">Huỷ</button>
        <button class="btn btn-primary" onclick="submitCreateKpi()">Lưu KPI</button>
      </div>
    </div>
  </div>

  <!-- Modal Cập nhật Actual -->
  <div id="modal-update-actual" class="modal" style="display:none">
    <div class="modal-content" style="max-width:380px">
      <div class="modal-header">
        <h3>Cập nhật kết quả thực tế</h3>
        <button class="btn-close" onclick="closeModal('modal-update-actual')">×</button>
      </div>
      <div class="modal-body" style="display:flex;flex-direction:column;gap:12px">
        <p id="update-kpi-name" style="font-weight:600;color:var(--text-1)"></p>
        <div class="form-group">
          <label>Kết quả Actual *</label>
          <input id="update-actual-val" type="number" class="form-control">
        </div>
        <div class="form-group">
          <label>Ghi chú</label>
          <input id="update-actual-note" class="form-control">
        </div>
        <input type="hidden" id="update-kpi-id">
      </div>
      <div class="modal-footer">
        <button class="btn btn-ghost" onclick="closeModal('modal-update-actual')">Huỷ</button>
        <button class="btn btn-primary" onclick="submitUpdateActual()">Cập nhật</button>
      </div>
    </div>
  </div>

  <!-- Modal Performance Review -->
  <div id="modal-review" class="modal" style="display:none">
    <div class="modal-content" style="max-width:560px">
      <div class="modal-header">
        <h3>📊 Đánh giá Hiệu suất (360°)</h3>
        <button class="btn-close" onclick="closeModal('modal-review')">×</button>
      </div>
      <div class="modal-body" style="display:flex;flex-direction:column;gap:14px">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group">
            <label>Nhân sự *</label>
            <select id="rv-ns" class="form-control"></select>
          </div>
          <div class="form-group">
            <label>Kỳ đánh giá *</label>
            <input id="rv-period" class="form-control" placeholder="Q2/2026">
          </div>
        </div>
        <div style="background:#F4F4F2;border-radius:10px;padding:14px">
          <p style="font-size:12px;color:var(--text-3);margin:0 0 10px">
            Trọng số: Tự đánh giá 20% | Quản lý 60% | Đồng nghiệp 20%</p>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">
            <div class="form-group">
              <label>Tự đánh giá (0–100)</label>
              <input id="rv-self" type="number" class="form-control" min="0" max="100">
            </div>
            <div class="form-group">
              <label>Quản lý (0–100)</label>
              <input id="rv-manager" type="number" class="form-control" min="0" max="100">
            </div>
            <div class="form-group">
              <label>Đồng nghiệp (0–100)</label>
              <input id="rv-peer" type="number" class="form-control" min="0" max="100" placeholder="Để trống nếu không có">
            </div>
          </div>
        </div>
        <div class="form-group">
          <label>Nhận xét tự đánh giá</label>
          <textarea id="rv-self-comment" class="form-control" rows="2"></textarea>
        </div>
        <div class="form-group">
          <label>Nhận xét quản lý</label>
          <textarea id="rv-manager-comment" class="form-control" rows="2"></textarea>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group">
            <label>Điểm mạnh</label>
            <textarea id="rv-strengths" class="form-control" rows="2"></textarea>
          </div>
          <div class="form-group">
            <label>Cần cải thiện</label>
            <textarea id="rv-improvements" class="form-control" rows="2"></textarea>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-ghost" onclick="closeModal('modal-review')">Huỷ</button>
        <button class="btn btn-primary" onclick="submitReview()">Lưu đánh giá</button>
      </div>
    </div>
  </div>
</div>

<script>
// ──────── KPI JS ────────
let _kpiData = [];
let _kpiNsList = [];
let _currentKpiId = null;

function initKpi() {
  google.script.run.withSuccessHandler(res => {
    _kpiNsList = res.success ? res.data.filter(n => n.Trang_Thai !== 'Đã nghỉ') : [];
    ['kpi-ns-filter','kpi-ns-sel','score-ns-sel','rv-ns'].forEach(selId => {
      const sel = document.getElementById(selId);
      if (!sel) return;
      _kpiNsList.forEach(ns => {
        sel.appendChild(new Option(ns.Ho_Ten + ' (' + (ns.Bo_Phan||'') + ')', ns.ID_NhanSu));
      });
    });
    // Set default period
    const period = document.getElementById('kpi-period');
    if (period) period.value = 'Q2/2026';
    const rv = document.getElementById('rv-period');
    if (rv) rv.value = 'Q2/2026';

    loadKpiDashboard();
  }).handleRequest({ action: 'GET_NHAN_SU_LIST', payload: {} });
}

function loadKpiDashboard() {
  const period = document.getElementById('kpi-period-filter').value;
  showLoading();
  google.script.run
    .withSuccessHandler(res => {
      hideLoading();
      if (!res.success) return;
      _kpiData = res.data;
      updateKpiCards();
      loadKpiTable();
    })
    .handleRequest({ action: 'GET_KPI_LIST', payload: { period } });
}

function updateKpiCards() {
  const active = _kpiData.filter(k => k.Status === 'Active').length;
  const above100 = _kpiData.filter(k => parseFloat(k.Score_Pct) >= 100).length;
  const above80 = _kpiData.filter(k => {
    const s = parseFloat(k.Score_Pct);
    return s >= 80 && s < 100;
  }).length;
  const below80 = _kpiData.filter(k => k.Score_Pct !== '' && parseFloat(k.Score_Pct) < 80).length;

  document.getElementById('kpi-total-active').textContent = active;
  document.getElementById('kpi-above-100').textContent = above100;
  document.getElementById('kpi-above-80').textContent = above80;
  document.getElementById('kpi-below-80').textContent = below80;
}

function loadKpiTable() {
  const nsFilter = document.getElementById('kpi-ns-filter').value;
  let data = nsFilter ? _kpiData.filter(k => k.ID_NhanSu === nsFilter) : _kpiData;

  const tbody = document.getElementById('kpi-tbody');
  if (data.length === 0) {
    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--text-3);padding:32px">Không có KPI nào</td></tr>';
    return;
  }

  tbody.innerHTML = data.map(k => {
    const score = k.Score_Pct !== '' ? parseFloat(k.Score_Pct) : null;
    const scoreBg = score === null ? '' : score >= 100 ? '#E1F5EE' : score >= 80 ? '#FAEEDA' : '#FCEBEB';
    const scoreColor = score === null ? '#888' : score >= 100 ? '#1D9E75' : score >= 80 ? '#BA7517' : '#C0392B';
    const scoreText = score !== null ? score + '%' : '—';

    return '<tr>' +
      '<td><span style="font-weight:600">' + escHtml(k.Ho_Ten_NS) + '</span><br>' +
      '<small style="color:var(--text-3)">' + escHtml(k.Bo_Phan||'') + '</small></td>' +
      '<td>' + escHtml(k.KPI_Name) + '</td>' +
      '<td style="text-align:right">' + (k.Target||'—') + '</td>' +
      '<td style="text-align:right">' + (k.Actual !== '' ? k.Actual : '—') + '</td>' +
      '<td style="text-align:center"><span style="background:' + scoreBg + ';color:' + scoreColor +
        ';font-weight:700;padding:3px 10px;border-radius:20px;font-size:13px">' + scoreText + '</span></td>' +
      '<td style="text-align:center">' + (k.Weight||'') + '</td>' +
      '<td><button class="btn btn-ghost" style="font-size:12px;padding:4px 10px" ' +
        'onclick="openUpdateActual(\'' + k.ID_KPI + '\',\'' + escHtml(k.KPI_Name) + '\')">Nhập kết quả</button></td>' +
      '</tr>';
  }).join('');
}

function filterKpiTable() {
  const q = document.getElementById('kpi-search').value.toLowerCase();
  document.querySelectorAll('#kpi-tbody tr').forEach(tr => {
    tr.style.display = tr.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}

function openKpiModal(mode) {
  document.getElementById('kpi-modal-title').textContent = 'Tạo KPI mới';
  ['kpi-name','kpi-target','kpi-actual','kpi-note'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
  document.getElementById('kpi-weight').value = '0.2';
  document.getElementById('kpi-period').value = document.getElementById('kpi-period-filter').value;
  document.getElementById('modal-kpi').style.display = 'flex';
}

function openUpdateActual(kpiId, kpiName) {
  _currentKpiId = kpiId;
  document.getElementById('update-kpi-id').value = kpiId;
  document.getElementById('update-kpi-name').textContent = kpiName;
  document.getElementById('update-actual-val').value = '';
  document.getElementById('update-actual-note').value = '';
  document.getElementById('modal-update-actual').style.display = 'flex';
}

function openReviewModal() {
  document.getElementById('modal-review').style.display = 'flex';
}

function submitCreateKpi() {
  const nsEl = document.getElementById('kpi-ns-sel');
  const nsId = nsEl.value;
  const hoTen = nsEl.options[nsEl.selectedIndex]?.text?.split('(')[0]?.trim() || '';
  const boPhan = nsEl.options[nsEl.selectedIndex]?.text?.match(/\(([^)]+)\)/)?.[1] || '';
  const name = document.getElementById('kpi-name').value.trim();
  const target = document.getElementById('kpi-target').value;
  const weight = document.getElementById('kpi-weight').value;

  if (!nsId || !name || !target || !weight) {
    showToast('Vui lòng điền đầy đủ thông tin bắt buộc', 'error'); return;
  }

  showLoading();
  const payload = {
    id_nhan_su: nsId, ho_ten_ns: hoTen, bo_phan: boPhan,
    kpi_name: name,
    period: document.getElementById('kpi-period').value || document.getElementById('kpi-period-filter').value,
    target: parseFloat(target), weight: parseFloat(weight),
    note: document.getElementById('kpi-note').value
  };

  const actual = document.getElementById('kpi-actual').value;
  if (actual !== '') payload.actual = parseFloat(actual);

  google.script.run
    .withSuccessHandler(res => {
      hideLoading();
      if (res.success) {
        showToast('Đã tạo KPI ✅');
        closeModal('modal-kpi');
        loadKpiDashboard();
      } else { showToast(res.error, 'error'); }
    })
    .handleRequest({ action: 'CREATE_KPI', payload });
}

function submitUpdateActual() {
  const kpiId = document.getElementById('update-kpi-id').value;
  const actual = document.getElementById('update-actual-val').value;
  if (!actual && actual !== 0) { showToast('Vui lòng nhập kết quả Actual', 'error'); return; }

  showLoading();
  google.script.run
    .withSuccessHandler(res => {
      hideLoading();
      if (res.success) {
        showToast('Đã cập nhật! Điểm: ' + res.score_pct + '%');
        closeModal('modal-update-actual');
        loadKpiDashboard();
      } else { showToast(res.error, 'error'); }
    })
    .handleRequest({
      action: 'UPDATE_KPI_ACTUAL',
      payload: {
        id: kpiId, actual: parseFloat(actual),
        note: document.getElementById('update-actual-note').value
      }
    });
}

function submitReview() {
  const nsEl = document.getElementById('rv-ns');
  const nsId = nsEl.value;
  const hoTen = nsEl.options[nsEl.selectedIndex]?.text?.split('(')[0]?.trim() || '';
  const period = document.getElementById('rv-period').value.trim();
  if (!nsId || !period) { showToast('Vui lòng chọn nhân sự và kỳ đánh giá', 'error'); return; }

  showLoading();
  google.script.run
    .withSuccessHandler(res => {
      hideLoading();
      if (res.success) {
        showToast('Đã lưu đánh giá! Điểm tổng: ' + res.final_score + ' ✅');
        closeModal('modal-review');
      } else { showToast(res.error, 'error'); }
    })
    .handleRequest({
      action: 'CREATE_PERFORMANCE_REVIEW',
      payload: {
        id_nhan_su: nsId, ho_ten_ns: hoTen, period,
        self_score: document.getElementById('rv-self').value,
        manager_score: document.getElementById('rv-manager').value,
        peer_score: document.getElementById('rv-peer').value || 0,
        self_comment: document.getElementById('rv-self-comment').value,
        manager_comment: document.getElementById('rv-manager-comment').value,
        strengths: document.getElementById('rv-strengths').value,
        improvements: document.getElementById('rv-improvements').value
      }
    });
}

function loadIndividualScore() {
  const nsId = document.getElementById('score-ns-sel').value;
  const period = document.getElementById('kpi-period-filter').value;
  if (!nsId) return;

  google.script.run
    .withSuccessHandler(res => {
      if (!res.success) return;
      const d = res.data;
      const scoreColor = d.weighted_score >= 100 ? '#1D9E75'
        : d.weighted_score >= 80 ? '#BA7517' : '#C0392B';
      const area = document.getElementById('individual-score-area');
      if (d.kpis.length === 0) {
        area.innerHTML = '<p style="color:var(--text-3)">Chưa có KPI nào trong kỳ ' + period + '</p>';
        return;
      }
      area.innerHTML =
        '<div style="font-size:48px;font-weight:800;color:' + scoreColor + '">' +
          d.weighted_score + '%</div>' +
        '<div style="color:var(--text-3);font-size:13px;margin-bottom:14px">Điểm KPI weighted trung bình</div>' +
        '<div style="display:flex;flex-direction:column;gap:6px">' +
        d.kpis.map(k => {
          const s = parseFloat(k.Score_Pct)||0;
          const bg = s>=100?'#E1F5EE':s>=80?'#FAEEDA':'#FCEBEB';
          const c = s>=100?'#1D9E75':s>=80?'#BA7517':'#C0392B';
          return '<div style="display:flex;justify-content:space-between;align-items:center;' +
            'padding:6px 10px;background:#F7F6F3;border-radius:8px;font-size:13px">' +
            '<span style="flex:1;text-align:left">' + escHtml(k.KPI_Name) + '</span>' +
            '<span style="font-weight:700;color:' + c + ';background:' + bg +
              ';padding:2px 8px;border-radius:12px;font-size:12px">' +
              (k.Score_Pct !== '' ? k.Score_Pct + '%' : '—') + '</span>' +
            '</div>';
        }).join('') +
        '</div>';
    })
    .handleRequest({ action: 'GET_KPI_WEIGHTED_SCORE', payload: { nsId, period } });
}

function runAiSuggestKpi() {
  const chucVu = document.getElementById('ai-chuc-vu').value.trim();
  const boPhan = document.getElementById('ai-bo-phan').value.trim();
  if (!chucVu) { showToast('Vui lòng nhập chức vụ', 'error'); return; }

  const resultDiv = document.getElementById('ai-kpi-result');
  resultDiv.style.display = 'block';
  resultDiv.innerHTML = '<div style="text-align:center;padding:16px;color:var(--text-3)">✨ AI đang phân tích...</div>';

  google.script.run
    .withSuccessHandler(res => {
      if (!res.success) {
        resultDiv.innerHTML = '<p style="color:#C0392B">Lỗi: ' + res.error + '</p>';
        return;
      }
      const d = res.data;
      resultDiv.innerHTML =
        '<p style="font-size:12px;color:var(--text-3);margin:0 0 10px">' + (d.note||'') + '</p>' +
        d.kpis.map(k =>
          '<div style="background:#F7F6F3;border-radius:8px;padding:10px;margin-bottom:8px">' +
          '<div style="font-weight:600;font-size:13px">' + escHtml(k.name) + ' <span style="font-size:11px;' +
            'color:#3D35A8;background:#EEEDFE;padding:1px 7px;border-radius:10px">W:' + k.weight + '</span></div>' +
          '<div style="font-size:12px;color:var(--text-3);margin:3px 0">' + escHtml(k.description) + '</div>' +
          '<div style="font-size:12px;color:#1D9E75">🎯 ' + escHtml(k.target_example) + '</div>' +
          '<button onclick="prefillKpiFromSuggest(\'' + escHtml(k.name).replace(/'/g,"\\'")+'\','+k.weight+')" ' +
            'style="font-size:11px;margin-top:6px;background:#3D35A8;color:#fff;border:none;' +
            'border-radius:6px;padding:3px 10px;cursor:pointer">+ Thêm KPI này</button>' +
          '</div>'
        ).join('');
    })
    .handleRequest({
      action: 'AI_SUGGEST_KPI',
      payload: {
        chuc_vu: chucVu, bo_phan: boPhan,
        period: document.getElementById('kpi-period-filter').value
      }
    });
}

function prefillKpiFromSuggest(name, weight) {
  document.getElementById('kpi-name').value = name;
  document.getElementById('kpi-weight').value = weight;
  document.getElementById('modal-kpi').style.display = 'flex';
}

function escHtml(str) {
  if (!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

initKpi();
</script>`;
}

/**
 * Helper để tích hợp tab GĐ4 vào buildFullApp() của GĐ2
 * Thêm 2 case này vào switch(page) trong buildFullApp():
 *
 *   case 'onboarding':
 *     contentHtml = getOnboardingTabHtml();
 *     break;
 *   case 'kpi':
 *     contentHtml = getKpiTabHtml();
 *     break;
 *
 * Và thêm 2 nav item vào sidebar HTML của GĐ2:
 *
 *   <a class="nav-item ${page==='onboarding'?'active':''}" onclick="navigate('onboarding')">
 *     📋 Onboarding
 *   </a>
 *   <a class="nav-item ${page==='kpi'?'active':''}" onclick="navigate('kpi')">
 *     🎯 KPI & Hiệu suất
 *   </a>
 */
function buildMainApp_GD4_NavItems(page) {
  // Trả về HTML nav items để nhúng vào sidebar GĐ2
  return `
    <a class="nav-item ${page === 'onboarding' ? 'active' : ''}" onclick="navigate('onboarding')" style="cursor:pointer">
      📋 Onboarding
    </a>
    <a class="nav-item ${page === 'kpi' ? 'active' : ''}" onclick="navigate('kpi')" style="cursor:pointer">
      🎯 KPI & Hiệu suất
    </a>`;
}

/**
 * Override getDashboardStats để bổ sung stats GĐ4
 * (Tích hợp vào getDashboardStats() của GĐ 1)
 */
function getDashboardStats_GD4_Extra(user) {
  const stats = {};
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();

    // Onboarding stats
    const obSheet = ss.getSheetByName('ONBOARDING_TASKS');
    if (obSheet) {
      const obData = obSheet.getDataRange().getValues().slice(1).filter(r => r[0]);
      stats.onboarding_pending = obData.filter(r => r[7] === 'Pending').length;
      stats.onboarding_done = obData.filter(r => r[7] === 'Done').length;
    }

    // KPI stats kỳ hiện tại
    const kpiSheet = ss.getSheetByName('KPI');
    if (kpiSheet) {
      const period = getCurrentPeriod();
      const kpiData = kpiSheet.getDataRange().getValues().slice(1)
        .filter(r => r[0] && r[4] === period && r[10] === 'Active');
      stats.kpi_active_count = kpiData.length;
      const scored = kpiData.filter(r => r[9] !== '' && r[9] !== null);
      stats.kpi_avg_score = scored.length > 0
        ? Math.round(scored.reduce((s, r) => s + parseFloat(r[9] || 0), 0) / scored.length)
        : 0;
    }
  } catch (e) {
    Logger.log('getDashboardStats_GD4_Extra error: ' + e.message);
  }
  return stats;
}

    const parsed = JSON.parse(jsonStr);

    writeAuditLog('CREATE', 'AI_RESULTS', 'KPI_SUGGEST', '', '',
      data.chuc_vu, 'AI gợi ý KPI');
    return { success: true, data: parsed };

  } catch (e) {
    Logger.log('aiSuggestKpi error: ' + e.message);
    return { success: false, error: 'AI gặp lỗi: ' + e.message };
  }
}

/**
 * Helper: Lấy kỳ đánh giá hiện tại (Q1/2026 format)
 */
function getCurrentPeriod() {
  const now = new Date();
  const q = Math.ceil((now.getMonth() + 1) / 3);
  return `Q${q}/${now.getFullYear()}`;
}

// =============================================================================
// MODULE 24 — handleRequest() MỞ RỘNG GĐ 4
// GHI CHÚ: Thay thế toàn bộ hàm handleRequest() hiện tại bằng hàm này
// =============================================================================

function handleRequest(request) {
  const user = getCurrentUser();
  if (!user.email || !user.role) {
    return { success: false, error: 'Không có quyền truy cập.' };
  }

  const { action, payload } = request;

  try {
    switch (action) {
      // ═══ GĐ 1 ═══
      case 'GET_NHAN_SU_LIST':
        if (!hasPermission(user.role, 'READ')) throw new Error('Không có quyền');
        return { success: true, data: getNhanSuList(user) };

      case 'CREATE_NHAN_SU':
        if (!hasPermission(user.role, 'WRITE')) throw new Error('Không có quyền');
        return createNhanSu(payload, user);

      case 'UPDATE_NHAN_SU':
        if (!hasPermission(user.role, 'WRITE')) throw new Error('Không có quyền');
        return updateNhanSu(payload, user);

      case 'DELETE_NHAN_SU':
        if (!hasPermission(user.role, 'DELETE')) throw new Error('Không có quyền');
        return deleteNhanSu(payload.id, user);

      case 'GET_DASHBOARD_STATS':
        if (!hasPermission(user.role, 'READ')) throw new Error('Không có quyền');
        return { success: true, data: getDashboardStats(user) };

      case 'GET_AUDIT_LOG':
        if (!hasPermission(user.role, 'ADMIN')) throw new Error('Chỉ Admin');
        return { success: true, data: getAuditLog(payload) };

      // ═══ GĐ 2 ═══
      case 'GET_UNG_VIEN_LIST':
        return { success: true, data: getUngVienList(user) };

      case 'CREATE_UNG_VIEN':
        if (!hasPermission(user.role, 'WRITE')) throw new Error('Không có quyền');
        return createUngVien(payload, user);

      case 'UPDATE_UNG_VIEN_STATUS':
        if (!hasPermission(user.role, 'WRITE')) throw new Error('Không có quyền');
        return updateUngVienStatus(payload, user);

      case 'GET_PHONG_VAN_LIST':
        return { success: true, data: getPhongVanList(user) };

      case 'CREATE_PHONG_VAN':
        if (!hasPermission(user.role, 'WRITE')) throw new Error('Không có quyền');
        return createPhongVan(payload, user);

      case 'GET_CHART_DATA':
        return { success: true, data: getChartData(user) };

      case 'GET_SINH_NHAT':
        return { success: true, data: getSinhNhatTuanNay() };

      // ═══ GĐ 3 ═══
      case 'AI_CHAT':
        return aiChat(payload);

      case 'AI_ANALYZE_CV':
        return aiAnalyzeCV(payload);

      case 'AI_SUMMARIZE_INTERVIEW':
        return aiSummarizeInterview(payload);

      case 'AI_ANALYZE_TURNOVER':
        return aiAnalyzeTurnoverRisk();

      case 'AI_GENERATE_JD':
        return aiGenerateJD(payload);

      // ═══ GĐ 4 — ONBOARDING ═══
      case 'GET_ONBOARDING_TASKS':
        if (!hasPermission(user.role, 'READ')) throw new Error('Không có quyền');
        return { success: true, data: getOnboardingTasks(payload) };

      case 'CREATE_ONBOARDING_CHECKLIST':
        if (!hasPermission(user.role, 'WRITE')) throw new Error('Không có quyền');
        return createOnboardingChecklist(payload.nsId, payload.hoTen, user.email);

      case 'UPDATE_ONBOARDING_TASK':
        if (!hasPermission(user.role, 'WRITE')) throw new Error('Không có quyền');
        return updateOnboardingTask(payload, user);

      case 'ADD_ONBOARDING_TASK':
        if (!hasPermission(user.role, 'WRITE')) throw new Error('Không có quyền');
        return addOnboardingTask(payload, user);

      case 'GET_ONBOARDING_PROGRESS':
        if (!hasPermission(user.role, 'READ')) throw new Error('Không có quyền');
        return { success: true, data: getOnboardingProgress(payload.nsId) };

      // ═══ GĐ 4 — KPI ═══
      case 'GET_KPI_LIST':
        if (!hasPermission(user.role, 'READ')) throw new Error('Không có quyền');
        return { success: true, data: getKpiList(payload) };

      case 'CREATE_KPI':
        if (!hasPermission(user.role, 'WRITE')) throw new Error('Không có quyền');
        return createKpi(payload, user);

      case 'UPDATE_KPI_ACTUAL':
        if (!hasPermission(user.role, 'WRITE')) throw new Error('Không có quyền');
        return updateKpiActual(payload, user);

      case 'GET_KPI_WEIGHTED_SCORE':
        if (!hasPermission(user.role, 'READ')) throw new Error('Không có quyền');
        return { success: true, data: calcWeightedScore(payload.nsId, payload.period) };

      case 'GET_KPI_SUMMARY_ALL':
        if (!hasPermission(user.role, 'READ')) throw new Error('Không có quyền');
        return { success: true, data: getKpiSummaryAll(payload && payload.period) };

      case 'CREATE_PERFORMANCE_REVIEW':
        if (!hasPermission(user.role, 'WRITE')) throw new Error('Không có quyền');
        return createPerformanceReview(payload, user);

      case 'AI_SUGGEST_KPI':
        if (!hasPermission(user.role, 'READ')) throw new Error('Không có quyền');
        return aiSuggestKpi(payload);

      default:
        return { success: false, error: 'Action không hợp lệ: ' + action };
    }
  } catch (e) {
    writeAuditLog('ERROR', 'SYSTEM', '', action, '', '', e.message);
    return { success: false, error: e.message };
  }
}


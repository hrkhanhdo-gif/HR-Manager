/**
 * Tạo mới KPI
 */
function createKpi(data, user) {
  if (!data.id_nhan_su || !data.kpi_name) {
    return { success: false, error: 'Thiếu ID nhân sự hoặc tên KPI' };
  }
  if (!data.target || isNaN(parseFloat(data.target))) {
    return { success: false, error: 'Mục tiêu (Target) phải là số' };
  }
  if (!data.weight || isNaN(parseFloat(data.weight))) {
    return { success: false, error: 'Trọng số (Weight) phải là số' };
  }

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('KPI') || setupKpiSheet();
  const id = generateId('KPI');
  const period = data.period || getCurrentPeriod();
  const weight = parseFloat(data.weight);
  const target = parseFloat(data.target);

  sheet.appendRow([
    id, data.id_nhan_su, data.ho_ten_ns || '', data.bo_phan || '',
    period, data.kpi_name, target, '', weight, '',
    'Active', data.note || '', new Date(), user.email
  ]);

  writeAuditLog('CREATE', 'KPI', id, '', '', data.kpi_name,
    `KPI cho ${data.ho_ten_ns} - ${period}`);
  return { success: true, id };
}

/**
 * Cập nhật kết quả thực tế (Actual) của KPI
 */
function updateKpiActual(data, user) {
  if (!data.id) return { success: false, error: 'Thiếu ID KPI' };
  if (data.actual === undefined || data.actual === '') {
    return { success: false, error: 'Thiếu giá trị Actual' };
  }

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('KPI');
  if (!sheet) return { success: false, error: 'Sheet KPI không tồn tại' };

  const allData = sheet.getDataRange().getValues();
  for (let i = 1; i < allData.length; i++) {
    if (allData[i][0] === data.id) {
      const target = parseFloat(allData[i][6]);
      const actual = parseFloat(data.actual);
      const scorePct = target > 0 ? Math.round((actual / target) * 100) : 0;

      sheet.getRange(i + 1, 8).setValue(actual);
      sheet.getRange(i + 1, 10).setValue(scorePct);

      // Màu row theo % đạt
      const bg = scorePct >= 100 ? '#E1F5EE'
        : scorePct >= 80 ? '#FAEEDA'
        : '#FCEBEB';
      sheet.getRange(i + 1, 1, 1, allData[0].length).setBackground(bg);

      if (data.note) sheet.getRange(i + 1, 12).setValue(data.note);

      writeAuditLog('UPDATE', 'KPI', data.id, 'Actual',
        allData[i][7], actual, `Score: ${scorePct}%`);

      return { success: true, score_pct: scorePct };
    }
  }
  return { success: false, error: 'Không tìm thấy KPI' };
}

/**
 * Lấy danh sách KPI (lọc theo nsId hoặc period)
 */
function getKpiList(options) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('KPI');
  if (!sheet) return [];

  const data = sheet.getDataRange().getValues();
  if (data.length < 2) return [];

  const headers = data[0].map(h => h.toString());
  let rows = data.slice(1).filter(r => r[0] !== '').map(row => {
    const obj = {};
    headers.forEach((h, i) => {
      obj[h] = row[i] instanceof Date ? row[i].toISOString() : row[i];
    });
    return obj;
  });

  if (options && options.nsId) {
    rows = rows.filter(r => r['ID_NhanSu'] === options.nsId);
  }
  if (options && options.period) {
    rows = rows.filter(r => r['Period'] === options.period);
  }
  return rows;
}

/**
 * Tính tổng KPI score weighted cho một nhân sự trong một kỳ
 */
function calcWeightedScore(nsId, period) {
  const kpis = getKpiList({ nsId, period });
  if (kpis.length === 0) return { kpis: [], weighted_score: 0, total_weight: 0 };

  let totalWeight = 0;
  let weightedSum = 0;

  kpis.forEach(k => {
    const w = parseFloat(k['Weight']) || 0;
    const s = parseFloat(k['Score_Pct']) || 0;
    totalWeight += w;
    weightedSum += w * s;
  });

  const weightedScore = totalWeight > 0
    ? Math.round(weightedSum / totalWeight)
    : 0;

  return { kpis, weighted_score: weightedScore, total_weight: totalWeight };
}

/**
 * Lấy summary KPI cho tất cả nhân sự trong kỳ hiện tại
 */
function getKpiSummaryAll(period) {
  const p = period || getCurrentPeriod();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const nsSheet = ss.getSheetByName('NHAN_SU');
  if (!nsSheet) return [];

  const nsData = nsSheet.getDataRange().getValues().slice(1)
    .filter(r => r[0] && r[8] !== 'Đã nghỉ');

  return nsData.map(row => {
    const nsId = row[0];
    const result = calcWeightedScore(nsId, p);
    return {
      ID_NhanSu: nsId,
      Ho_Ten: row[1],
      Bo_Phan: row[2],
      Chuc_Vu: row[3],
      Period: p,
      Weighted_Score: result.weighted_score,
      KPI_Count: result.kpis.length
    };
  });
}

/**
 * Tạo Performance Review
 */
function createPerformanceReview(data, user) {
  if (!data.id_nhan_su || !data.period) {
    return { success: false, error: 'Thiếu ID nhân sự hoặc kỳ đánh giá' };
  }

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('PERFORMANCE_REVIEW') || setupPerformanceReviewSheet();
  const id = generateId('PR');

  const selfScore = parseFloat(data.self_score) || 0;
  const managerScore = parseFloat(data.manager_score) || 0;
  const peerScore = parseFloat(data.peer_score) || 0;
  // Trọng số: Self 20%, Manager 60%, Peer 20%
  const finalScore = Math.round(selfScore * 0.2 + managerScore * 0.6 + peerScore * 0.2);

  sheet.appendRow([
    id, data.id_nhan_su, data.ho_ten_ns || '', data.period,
    selfScore, managerScore, peerScore, finalScore,
    data.self_comment || '', data.manager_comment || '',
    data.strengths || '', data.improvements || '',
    'Completed', user.email, new Date()
  ]);

  writeAuditLog('CREATE', 'PERFORMANCE_REVIEW', id, '', '', data.id_nhan_su,
    `Review ${data.period} - Score: ${finalScore}`);
  return { success: true, id, final_score: finalScore };
}


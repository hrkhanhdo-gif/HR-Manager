<script>
// ──────── ONBOARDING JS ────────
let _onbTasks = [];
let _onbNsList = [];

function initOnboarding() {
  google.script.run.withSuccessHandler(res => {
    _onbNsList = res.success ? res.data.filter(n => n.Trang_Thai !== 'Đã nghỉ') : [];
    const sel = document.getElementById('onb-ns-filter');

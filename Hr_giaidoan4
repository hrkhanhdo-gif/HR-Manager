      const opt2 = new Option(ns.Ho_Ten + ' — ' + (ns.Bo_Phan||''), ns.ID_NhanSu);
      sel.appendChild(opt);
      sel2.appendChild(opt2);
    });
  }).handleRequest({ action: 'GET_NHAN_SU_LIST', payload: {} });
}

function loadOnboardingBoard() {
  const nsId = document.getElementById('onb-ns-filter').value;
  if (!nsId) {
    clearKanban();
    return;
  }
  showLoading();
  google.script.run
    .withSuccessHandler(res => {
      hideLoading();
      if (res.success) {
        _onbTasks = res.data;
        renderKanban();
        loadProgress(nsId);
      }
    })
    .handleRequest({ action: 'GET_ONBOARDING_TASKS', payload: { nsId } });
}

function renderKanban() {
  const statuses = ['Pending','In Progress','Done','Skip'];
  statuses.forEach(status => {
    const col = document.getElementById('onb-col-' + status);
    const badge = document.getElementById('onb-count-' + status);
    const tasks = _onbTasks.filter(t => t.Status === status);
    badge.textContent = tasks.length;
    badge.style.background = status==='Done'?'#1D9E75':status==='In Progress'?'#BA7517':status==='Skip'?'#888':'#3D35A8';
    badge.style.color = '#fff';
    if (tasks.length === 0) {
      col.innerHTML = '<p style="color:var(--text-3);font-size:13px;text-align:center;margin-top:32px;padding:8px">Không có task</p>';
      return;
    }
    col.innerHTML = tasks.map(t => buildTaskCard(t)).join('');
  });
}

function buildTaskCard(task) {
  const dl = task.Deadline ? new Date(task.Deadline) : null;
  const today = new Date();
  const isOverdue = dl && task.Status !== 'Done' && dl < today;
  const dlStr = dl ? dl.toLocaleDateString('vi-VN') : '—';
  const catColors = {HR:'#EEEDFE',IT:'#E1F5EE',Admin:'#FAEEDA',Legal:'#FCEBEB',Finance:'#E6F1FB',Training:'#F4F4F2'};

  return '<div class="task-card" style="background:#fff;border:1px solid var(--border-color,#E0DDD8);' +
    'border-radius:10px;padding:12px;cursor:pointer;transition:box-shadow .15s;' +
    (isOverdue ? 'border-left:3px solid #C0392B;' : '') + '" ' +
    'onmouseenter="this.style.boxShadow=\'0 4px 16px rgba(0,0,0,.1)\'" ' +
    'onmouseleave="this.style.boxShadow=\'none\'">' +
    '<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px">' +
    '<span style="font-size:13px;font-weight:600;color:var(--text-1);flex:1">' + escHtml(task.Task_Name) + '</span>' +
    '<span style="font-size:11px;font-weight:600;padding:2px 8px;border-radius:20px;white-space:nowrap;' +
    'background:' + (catColors[task.Category]||'#eee') + '">' + (task.Category||'') + '</span>' +
    '</div>' +
    (task.Assignee ? '<div style="font-size:12px;color:var(--text-3);margin-top:4px">👤 ' + escHtml(task.Assignee) + '</div>' : '') +
    '<div style="display:flex;justify-content:space-between;align-items:center;margin-top:10px">' +
    '<span style="font-size:11px;color:' + (isOverdue?'#C0392B':'var(--text-3)') + '">' +
    (isOverdue ? '🔴 Trễ hạn: ' : '📅 ') + dlStr + '</span>' +
    '<div style="display:flex;gap:6px">' +
    buildStatusButtons(task) +
    '</div>' +
    '</div>' +
    '</div>';
}

function buildStatusButtons(task) {
  const actions = {
    'Pending':     [['🔄','In Progress','Bắt đầu'],['⏭️','Skip','Bỏ qua']],
    'In Progress': [['✅','Done','Hoàn thành'],['⏳','Pending','Hoàn tác'],['⏭️','Skip','Bỏ qua']],
    'Done':        [['↩️','In Progress','Mở lại']],
    'Skip':        [['⏳','Pending','Khôi phục']]
  };
  return (actions[task.Status]||[]).map(([icon, newStatus, label]) =>
    '<button title="' + label + '" style="font-size:15px;background:none;border:1px solid #ddd;' +
    'border-radius:6px;padding:2px 7px;cursor:pointer" ' +
    'onclick="updateTask(\'' + task.ID_Task + '\',\'' + newStatus + '\')">' + icon + '</button>'
  ).join('');
}

function updateTask(taskId, newStatus) {

/**
 * Setup sheet ONBOARDING_TASKS
 */
function setupOnboardingSheet() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheetName = 'ONBOARDING_TASKS';
  let sheet = ss.getSheetByName(sheetName);
  if (!sheet) {
    sheet = ss.insertSheet(sheetName);
    const headers = [
      'ID_Task', 'ID_NhanSu', 'Ho_Ten_NS', 'Task_Name', 'Category',
      'Deadline', 'Assignee', 'Status', 'Done_At', 'Note',
      'Created_At', 'Created_By'
    ];
    sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
    sheet.getRange(1, 1, 1, headers.length)
      .setBackground('#1D9E75')
      .setFontColor('#FFFFFF')
      .setFontWeight('bold');
    sheet.setFrozenRows(1);

    // Data validation
    const categoryRule = SpreadsheetApp.newDataValidation()
      .requireValueInList(['HR', 'IT', 'Admin', 'Legal', 'Finance', 'Training'], true).build();
    sheet.getRange('E2:E2000').setDataValidation(categoryRule);

    const statusRule = SpreadsheetApp.newDataValidation()
      .requireValueInList(['Pending', 'In Progress', 'Done', 'Skip'], true).build();
    sheet.getRange('H2:H2000').setDataValidation(statusRule);

    const colWidths = [150, 150, 160, 250, 90, 110, 160, 100, 140, 200, 140, 160];
    colWidths.forEach((w, i) => sheet.setColumnWidth(i + 1, w));
    Logger.log('✅ Đã tạo sheet ONBOARDING_TASKS');
  }
  return sheet;
}

/**
 * Tạo checklist onboarding mặc định khi có nhân sự mới
 * @param {string} nsId - ID nhân sự
 * @param {string} hoTen - Họ tên nhân sự
 * @param {string} userEmail - Email người thực hiện
 */
function createOnboardingChecklist(nsId, hoTen, userEmail) {
  const DEFAULT_TASKS = [
    { name: 'Ký hợp đồng lao động',             category: 'Legal',    days: 1  },
    { name: 'Cấp thẻ nhân viên & pass cửa',      category: 'Admin',    days: 1  },
    { name: 'Tạo email công ty',                  category: 'IT',       days: 1  },
    { name: 'Cấp laptop & thiết bị làm việc',    category: 'IT',       days: 2  },
    { name: 'Cài đặt phần mềm cần thiết',        category: 'IT',       days: 3  },
    { name: 'Phổ biến nội quy công ty',           category: 'HR',       days: 2  },
    { name: 'Training quy trình làm việc',        category: 'Training', days: 5  },
    { name: 'Giới thiệu team & văn phòng',        category: 'HR',       days: 1  },
    { name: 'Đăng ký BHXH & phúc lợi',           category: 'Finance',  days: 7  },
    { name: 'Mở tài khoản ngân hàng nhận lương',  category: 'Finance',  days: 7  },
    { name: 'Hoàn thiện hồ sơ cá nhân (CMND, bằng cấp)', category: 'HR', days: 5 },
    { name: 'Đánh giá cuối thử việc 60 ngày',    category: 'HR',       days: 60 },
  ];

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('ONBOARDING_TASKS') || setupOnboardingSheet();
  const today = new Date();
  const rows = [];

  DEFAULT_TASKS.forEach(task => {
    const id = generateId('OT');
    const deadline = new Date(today);
    deadline.setDate(deadline.getDate() + task.days);
    rows.push([
      id, nsId, hoTen, task.name, task.category,
      deadline, '', 'Pending', '', '',
      today, userEmail || 'system'
    ]);
  });

  if (rows.length > 0) {
    sheet.getRange(sheet.getLastRow() + 1, 1, rows.length, rows[0].length).setValues(rows);
  }

  writeAuditLog('CREATE', 'ONBOARDING_TASKS', nsId, '', '', hoTen,
    `Tạo ${rows.length} task onboarding cho ${hoTen}`);

  return { success: true, count: rows.length };
}

/**
 * Lấy danh sách onboarding tasks (có thể lọc theo nsId)
 */
function getOnboardingTasks(options) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('ONBOARDING_TASKS');
  if (!sheet) return [];

  const data = sheet.getDataRange().getValues();
  if (data.length < 2) return [];

  const headers = data[0].map(h => h.toString());
  let rows = data.slice(1).filter(r => r[0] !== '').map(row => {
    const obj = {};
    headers.forEach((h, i) => {
      obj[h] = row[i] instanceof Date ? row[i].toISOString() : row[i];
    });
    return obj;
  });

  if (options && options.nsId) {
    rows = rows.filter(r => r['ID_NhanSu'] === options.nsId);
  }

  return rows;
}

/**
 * Cập nhật trạng thái một task onboarding
 */
function updateOnboardingTask(data, user) {
  if (!data.id) return { success: false, error: 'Thiếu ID task' };

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('ONBOARDING_TASKS');
  if (!sheet) return { success: false, error: 'Sheet ONBOARDING_TASKS không tồn tại' };

  const allData = sheet.getDataRange().getValues();
  for (let i = 1; i < allData.length; i++) {
    if (allData[i][0] === data.id) {
      const oldStatus = allData[i][7];
      sheet.getRange(i + 1, 8).setValue(data.status);

      // Ghi thời gian hoàn thành nếu Done
      if (data.status === 'Done') {
        sheet.getRange(i + 1, 9).setValue(new Date());
      } else {
        sheet.getRange(i + 1, 9).setValue('');
      }

      if (data.note !== undefined) sheet.getRange(i + 1, 10).setValue(data.note);
      if (data.assignee !== undefined) sheet.getRange(i + 1, 7).setValue(data.assignee);

      // Màu row theo status
      const colors = {
        'Done': '#E1F5EE',
        'In Progress': '#FAEEDA',
        'Pending': '#FFFFFF',
        'Skip': '#F4F4F2'
      };
      sheet.getRange(i + 1, 1, 1, allData[0].length)
        .setBackground(colors[data.status] || '#FFFFFF');

      writeAuditLog('UPDATE', 'ONBOARDING_TASKS', data.id, 'Status',
        oldStatus, data.status, `Task: ${allData[i][3]}`);

      return { success: true, message: 'Đã cập nhật task' };
    }
  }
  return { success: false, error: 'Không tìm thấy task' };
}

/**
 * Thêm task onboarding tùy chỉnh
 */
function addOnboardingTask(data, user) {
  if (!data.id_nhan_su || !data.task_name) {
    return { success: false, error: 'Thiếu ID nhân sự hoặc tên task' };
  }

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('ONBOARDING_TASKS') || setupOnboardingSheet();

  const id = generateId('OT');
  const deadline = data.deadline ? new Date(data.deadline) : '';

  sheet.appendRow([
    id, data.id_nhan_su, data.ho_ten_ns || '',
    data.task_name, data.category || 'HR',
    deadline, data.assignee || '', 'Pending', '', data.note || '',
    new Date(), user.email
  ]);

  writeAuditLog('CREATE', 'ONBOARDING_TASKS', id, '', '', data.task_name,
    'Thêm task thủ công');
  return { success: true, id };
}

/**
 * Tính % hoàn thành onboarding của một nhân sự
 */
function getOnboardingProgress(nsId) {
  const tasks = getOnboardingTasks({ nsId });
  if (tasks.length === 0) return { total: 0, done: 0, pct: 0 };
  const done = tasks.filter(t => t['Status'] === 'Done').length;
  return {
    total: tasks.length,
    done,
    pct: Math.round((done / tasks.length) * 100)
  };
}


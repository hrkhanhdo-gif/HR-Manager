  document.getElementById('onb-progress-label').textContent = 'Chọn nhân sự để xem tiến độ';
}

function escHtml(str) {
  if (!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// Tự khởi tạo khi tab được load
initOnboarding();
</script>`;

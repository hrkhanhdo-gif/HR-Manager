// FIX B-11: OPTIMISTIC LOCKING — CONCURRENT WRITE PROTECTION
// =============================================================================

/**
 * [B-03 + B-11 FIX] updateNhanSu() đã fix:
 * 1. Optimistic locking: kiểm tra Updated_At trước khi ghi
 * 2. Batch write: 1 setValues() thay vì N setValue() calls
 */
function updateNhanSu_fixed(data, user) {
  if (!data.id) return { success: false, error: 'Thiếu ID nhân sự' };

  const validation = validateNhanSu(data);
  if (!validation.valid) {
    return { success: false, error: validation.errors.join('\n') };
  }

  const ss    = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(CONFIG.SHEETS.NHAN_SU);
  if (!sheet) return { success: false, error: 'Không tìm thấy sheet NHAN_SU' };

  // Dùng LockService để tránh race condition
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(10000); // Chờ tối đa 10 giây
  } catch (e) {
    return { success: false, error: 'Hệ thống đang bận. Vui lòng thử lại sau vài giây.' };
  }

  try {
    const allData  = sheet.getDataRange().getValues();
    const headers  = allData[0].map(h => h.toString());

    // Map header → column index để tránh magic numbers [B-03]
    const col = (name) => headers.indexOf(name);
    const HO_TEN    = col('Ho_Ten');
    const BO_PHAN   = col('Bo_Phan');
    const CHUC_VU   = col('Chuc_Vu');
    const NGAY_VAO  = col('Ngay_Vao');
    const NGAY_SINH = col('Ngay_Sinh');
    const SDT       = col('SDT');
    const EMAIL     = col('Email');
    const TRANG_THAI= col('Trang_Thai');
    const LINK_HS   = col('Link_HoSo');
    const UPDATED_AT= col('Updated_At'); // cột mới — thêm vào sheet nếu chưa có
    const UPDATED_BY= col('Updated_By');

    for (let i = 1; i < allData.length; i++) {
      if (allData[i][0] !== data.id) continue;

      // [B-11] Optimistic locking: kiểm tra timestamp
      if (data.updated_at_check && UPDATED_AT !== -1) {
        const currentTs = allData[i][UPDATED_AT];
        const clientTs  = new Date(data.updated_at_check);
        // Nếu record đã được sửa sau thời điểm client đọc → conflict
        if (currentTs instanceof Date && clientTs < currentTs) {
          return {
            success: false,
            error: 'Dữ liệu đã bị thay đổi bởi người dùng khác. Vui lòng tải lại trang và thử lại.',
            conflict: true
          };
        }
      }

      const oldRow = [...allData[i]];
      const now    = new Date();

      // [B-03] Build entire row, ghi 1 lần bằng setValues()
      const newRow = [...allData[i]]; // copy row hiện tại

      if (HO_TEN    !== -1 && data.ho_ten    !== undefined) newRow[HO_TEN]    = data.ho_ten;
      if (BO_PHAN   !== -1 && data.bo_phan   !== undefined) newRow[BO_PHAN]   = data.bo_phan;
      if (CHUC_VU   !== -1 && data.chuc_vu   !== undefined) newRow[CHUC_VU]   = data.chuc_vu;
      if (NGAY_VAO  !== -1 && data.ngay_vao  !== undefined) newRow[NGAY_VAO]  = data.ngay_vao ? new Date(data.ngay_vao) : allData[i][NGAY_VAO];
      if (NGAY_SINH !== -1 && data.ngay_sinh !== undefined) newRow[NGAY_SINH] = data.ngay_sinh ? new Date(data.ngay_sinh) : allData[i][NGAY_SINH];
      if (SDT       !== -1 && data.sdt       !== undefined) newRow[SDT]       = data.sdt;
      if (EMAIL     !== -1 && data.email     !== undefined) newRow[EMAIL]      = data.email;
      if (TRANG_THAI!== -1 && data.trang_thai!== undefined) newRow[TRANG_THAI]= data.trang_thai;
      if (LINK_HS   !== -1 && data.link_ho_so!== undefined) newRow[LINK_HS]   = data.link_ho_so;
      if (UPDATED_AT!== -1) newRow[UPDATED_AT] = now;
      if (UPDATED_BY!== -1) newRow[UPDATED_BY] = user.email;

      // 1 lần ghi duy nhất [B-03 FIX]
      sheet.getRange(i + 1, 1, 1, newRow.length).setValues([newRow]);

      writeAuditLog('UPDATE', CONFIG.SHEETS.NHAN_SU, data.id, 'multiple',
        JSON.stringify(oldRow), JSON.stringify(data), `Cập nhật: ${data.ho_ten || ''}`);

      return {
        success: true,
        message: `Đã cập nhật thông tin ${data.ho_ten || ''}`,
        updated_at: now.toISOString()
      };
    }

    return { success: false, error: `Không tìm thấy nhân sự với ID: ${data.id}` };
  } finally {
    lock.releaseLock(); // Luôn giải phóng lock
  }
}

/**
 * [GĐ2-FIX] Lấy nhân sự theo ID để prefill Edit form
 */
function getNhanSuById(id) {
  if (!id) return { success: false, error: 'Thiếu ID' };

  const ss    = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(CONFIG.SHEETS.NHAN_SU);
  if (!sheet) return { success: false, error: 'Sheet không tồn tại' };

  const data    = sheet.getDataRange().getValues();
  const headers = data[0].map(h => h.toString());

  for (let i = 1; i < data.length; i++) {
    if (data[i][0] === id) {
      const obj = {};
      headers.forEach((h, idx) => {
        obj[h] = data[i][idx] instanceof Date ? data[i][idx].toISOString() : data[i][idx];
      });
      return { success: true, data: obj };
    }
  }
  return { success: false, error: 'Không tìm thấy nhân sự: ' + id };
}


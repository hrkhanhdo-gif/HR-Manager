// FIX B-06: callClaude() VỚI RETRY + EXPONENTIAL BACKOFF
// =============================================================================

/**
 * [B-06 FIX] callClaude() với retry logic
 * Tự động retry tối đa 3 lần khi gặp timeout hoặc rate limit (429)
 */
function callClaude(userMessage, systemPrompt, history, maxRetries) {
  const apiKey    = getApiKey();
  const retries   = maxRetries !== undefined ? maxRetries : 3;
  const messages  = [];

  if (history && Array.isArray(history)) {
    history.forEach(h => messages.push({ role: h.role, content: h.content }));
  }
  messages.push({ role: 'user', content: userMessage });

  const payload = {
    model:      AI_CONFIG.MODEL,
    max_tokens: AI_CONFIG.MAX_TOKENS,
    system:     systemPrompt || AI_CONFIG.HR_SYSTEM_PROMPT,
    messages,
  };

  const options = {
    method:      'post',
    contentType: 'application/json',
    headers: {
      'x-api-key':         apiKey,
      'anthropic-version': '2023-06-01',
    },
    payload:            JSON.stringify(payload),
    muteHttpExceptions: true,
  };

  let lastError;

  for (let attempt = 1; attempt <= retries; attempt++) {
    try {
      const response = UrlFetchApp.fetch(AI_CONFIG.API_URL, options);
      const status   = response.getResponseCode();
      const result   = JSON.parse(response.getContentText());

      // Rate limit (429) hoặc server error (5xx) → retry với backoff
      if (status === 429 || status >= 500) {
        const waitMs = Math.pow(2, attempt) * 1000; // 2s, 4s, 8s
        Logger.log(`callClaude attempt ${attempt} — HTTP ${status}, retry sau ${waitMs}ms`);
        if (attempt < retries) {
          Utilities.sleep(waitMs);
          continue;
        }
        throw new Error(`API trả về HTTP ${status} sau ${retries} lần thử`);
      }

      if (result.error) throw new Error(result.error.message);
      return result.content[0].text;

    } catch (e) {
      lastError = e;
      Logger.log(`callClaude attempt ${attempt} error: ${e.message}`);
      if (attempt < retries) {
        Utilities.sleep(Math.pow(2, attempt) * 500);
      }
    }
  }

  throw lastError || new Error('callClaude() thất bại sau ' + retries + ' lần thử');
}



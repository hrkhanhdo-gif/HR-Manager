    const mon = new Date(2026, 3, 27); // Thứ 2, 27/04/2026
    const fri = new Date(2026, 3, 30); // Thứ 5 (do 30/4 là lễ!)

    // 28/4 Thứ 3 → 29/4 Thứ 4: 2 ngày (30/4 là lễ, bỏ qua)
    const d1 = countWorkDays(new Date(2026, 3, 28), new Date(2026, 3, 29));
    assert('countWorkDays — 2 ngày thường trong tuần', d1 === 2);

    // 30/4 là ngày lễ → không tính
    const d2 = countWorkDays(new Date(2026, 3, 30), new Date(2026, 3, 30));
    assert('countWorkDays — 30/4 ngày lễ = 0 ngày', d2 === 0);

    // T7 CN không tính
    const d3 = countWorkDays(new Date(2026, 3, 25), new Date(2026, 3, 26)); // T7 + CN
    assert('countWorkDays — T7 CN = 0 ngày', d3 === 0);
  }

  // ── generateId ──
  {
    const id1 = generateId('NS');
    const id2 = generateId('NS');
    assert('generateId — format PREFIX-DATE-XXXX', id1.startsWith('NS-') && id1.length >= 14);
    assert('generateId — 2 ID liên tiếp khác nhau', id1 !== id2);
  }

  // ── escapeHtml ──
  {
    assert('escapeHtml — & escaped', escapeHtml('a & b') === 'a &amp; b');
    assert('escapeHtml — < > escaped', escapeHtml('<script>') === '&lt;script&gt;');
    assert('escapeHtml — " escaped', escapeHtml('"test"') === '&quot;test&quot;');
    assert('escapeHtml — null → empty string', escapeHtml(null) === '');
    assert('escapeHtml — undefined → empty string', escapeHtml(undefined) === '');
    assert('escapeHtml — số → string', escapeHtml(123) === '123');
    // XSS payload phải bị neutralize
    assert('escapeHtml — XSS neutralized',
      !escapeHtml('<img src=x onerror=alert(1)>').includes('<img')
    );
  }

  // ── validateUngVien ──
  {
    const uv1 = validateUngVien({ ho_ten: 'Ứng viên A', vi_tri_tuyen: 'Developer' });
    assert('validateUngVien — valid', uv1.valid === true);

    const uv2 = validateUngVien({ ho_ten: '', vi_tri_tuyen: '' });
    assert('validateUngVien — empty fields fail', uv2.valid === false);

    const uv3 = validateUngVien({ ho_ten: 'Test', vi_tri_tuyen: 'Dev', email: 'bad-email' });
    assert('validateUngVien — bad email fail', uv3.valid === false);
  }

  // Tóm tắt kết quả
  Logger.log('');
  Logger.log('═══════════════════════════════════════');
  Logger.log(`TEST RESULTS: ${passed} passed, ${failed} failed`);
  Logger.log('═══════════════════════════════════════');

  if (failed > 0) {
    Logger.log('\nFailed tests:');
    results.filter(r => !r.ok).forEach(r => Logger.log('  ❌ ' + r.name + ' — ' + r.detail));
  }

  // Hiển thị kết quả trong UI nếu chạy từ menu
  try {
    SpreadsheetApp.getUi().alert(
      `Test Results: ${passed}/${passed + failed} passed\n\n` +
      (failed > 0
        ? '❌ Failed:\n' + results.filter(r => !r.ok).map(r => '  • ' + r.name).join('\n')
        : '✅ Tất cả tests passed!')
    );
  } catch (e) {}

  return { passed, failed, results };
}



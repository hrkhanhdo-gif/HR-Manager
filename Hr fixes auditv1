function setupSystem() {
  const props = PropertiesService.getScriptProperties();

  // Guard: đã init rồi thì chỉ thông báo, không chạy lại
  const alreadyInit = props.getProperty('SYSTEM_INITIALIZED');
  if (alreadyInit === 'true') {
    try {
      SpreadsheetApp.getUi().alert(
        'ℹ️ Hệ thống đã được khởi tạo trước đó.\n\n' +
        'Nếu bạn muốn reset hoàn toàn, hãy chạy hàm resetSystem() trước.\n\n' +
        'Để cập nhật triggers, hãy chạy setupTriggers_safe().'
      );
    } catch (e) {}
    Logger.log('ℹ️ setupSystem() đã chạy trước đó — bỏ qua.');
    return;
  }

  Logger.log('🚀 Bắt đầu khởi tạo hệ thống HR lần đầu...');

  // 1. Tạo sheets (idempotent — chỉ tạo nếu chưa có)
  setupAuditLogSheet();
  setupPhanQuyenSheet();
  setupNhanSuSheet();
  setupUngVienSheet();

  // 2. Đặt trigger an toàn (không duplicate)
  setupTriggers_safe();

  // 3. Ghi flag đã init
  props.setProperty('SYSTEM_INITIALIZED', 'true');
  props.setProperty('SYSTEM_INIT_DATE', new Date().toISOString());
  props.setProperty('SYSTEM_VERSION', '1.0');

  writeAuditLog('CREATE', 'SYSTEM', 'SETUP', '', '', 'v1.0', 'Khởi tạo hệ thống HR lần đầu');
  Logger.log('✅ Khởi tạo hệ thống hoàn tất!');

  try {
    SpreadsheetApp.getUi().alert(
      '✅ Hệ thống HR đã được khởi tạo thành công!\n\n' +
      'Đã tạo:\n• Sheet AUDIT_LOG\n• Sheet PHAN_QUYEN\n• Sheet NHAN_SU\n• Sheet UNG_VIEN\n\n' +
      'Trigger tự động:\n• Backup hàng ngày lúc 11pm\n• Nhắc sinh nhật 8am\n• Audit log khi edit\n\n' +
      'Bước tiếp theo: Thêm email vào sheet PHAN_QUYEN'
    );
  } catch (e) {}
}

/**
 * Reset flag để có thể chạy setupSystem() lại — chỉ Admin dùng khi cần thiết
 */
function resetSystemFlag() {
  const user = getCurrentUser();
  if (!hasPermission(user.role, 'ADMIN')) {
    Logger.log('Chỉ Admin mới reset được system flag');
    return;
  }
  PropertiesService.getScriptProperties().deleteProperty('SYSTEM_INITIALIZED');
  Logger.log('⚠️ System flag đã được reset. Bạn có thể chạy setupSystem() lại.');
}


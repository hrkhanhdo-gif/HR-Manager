// FIX B-18: createKpi() VALIDATE TỔNG WEIGHT ≤ 1.0
// =============================================================================

/**
 * [B-18 FIX] createKpi() với validation tổng weight
 */
function createKpi_fixed(data, user) {
  // Validation cơ bản (từ GĐ4 giữ nguyên)
  if (!data.id_nhan_su || !data.kpi_name) {
    return { success: false, error: 'Thiếu ID nhân sự hoặc tên KPI' };
  }
  const weight = parseFloat(data.weight);
  const target = parseFloat(data.target);

  if (isNaN(target) || target <= 0) {
    return { success: false, error: 'Mục tiêu (Target) phải là số dương' };
  }
  if (isNaN(weight) || weight <= 0 || weight > 1) {
    return { success: false, error: 'Trọng số (Weight) phải từ 0.01 đến 1.0' };
  }

  // [B-18] Kiểm tra tổng weight của tất cả KPI trong cùng kỳ không vượt 1.0
  const period       = data.period || getCurrentPeriod();
  const existingKpis = getKpiList({ nsId: data.id_nhan_su, period });
  const totalWeight  = existingKpis.reduce((sum, k) => sum + (parseFloat(k.Weight) || 0), 0);

  if (totalWeight + weight > 1.001) { // dùng 1.001 để tránh floating point rounding
    const remaining = Math.round((1.0 - totalWeight) * 100) / 100;
    return {
      success: false,
      error: `Tổng trọng số đã là ${Math.round(totalWeight * 100)}%. Bạn chỉ có thể thêm tối đa ${remaining} weight nữa.`,
      current_total: totalWeight,
      remaining
    };
  }

  // Gọi createKpi() gốc sau khi đã validate
  return createKpi(data, user);
}



// =============================================================================

/**
 * [B-12 FIX] generateId() thread-safe với LockService
 * Format: PREFIX-YYYYMMDD-XXXX (counter tăng dần trong ngày, không random)
 */
function generateId(prefix) {
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(5000);
    const dateStr  = Utilities.formatDate(new Date(), 'Asia/Ho_Chi_Minh', 'yyyyMMdd');
    const counterKey = 'ID_COUNTER_' + prefix + '_' + dateStr;
    const props    = PropertiesService.getScriptProperties();
    const current  = parseInt(props.getProperty(counterKey) || '0') + 1;
    props.setProperty(counterKey, String(current));
    return `${prefix}-${dateStr}-${String(current).padStart(4, '0')}`;
  } catch (e) {
    // Fallback nếu lock timeout
    const dateStr = Utilities.formatDate(new Date(), 'Asia/Ho_Chi_Minh', 'yyyyMMdd');
    return `${prefix}-${dateStr}-${String(Math.floor(Math.random() * 9000) + 1000)}`;
  } finally {
    lock.releaseLock();
  }
}



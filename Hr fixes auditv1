/**
 * Override writeAuditLog để tự động invalidate cache sau CREATE/UPDATE/DELETE
 * Thay thế writeAuditLog() gốc trong GĐ1
 */
function writeAuditLog(action, sheetName, rowId, fieldChanged, oldValue, newValue, note) {
  try {
    const ss       = SpreadsheetApp.getActiveSpreadsheet();
    const logSheet = ss.getSheetByName(CONFIG.SHEETS.AUDIT_LOG);
    if (!logSheet) return;

    const user      = getCurrentUser();
    const timestamp = new Date();

    const logRow = [
      timestamp,
      user.email || 'system',
      user.role || 'SYSTEM',
      action,
      sheetName,
      rowId || '',
      fieldChanged || '',
      oldValue !== undefined ? String(oldValue) : '',
      newValue !== undefined ? String(newValue) : '',
      note || '',
    ];

    logSheet.appendRow(logRow);

    const lastRow     = logSheet.getLastRow();
    const actionColors = {
      CREATE: '#EAF3DE',
      UPDATE: '#FAEEDA',
      DELETE: '#FCEBEB',
      LOGIN:  '#E6F1FB',
      ERROR:  '#FAECE7',
    };
    const bgColor = actionColors[action] || '#F1EFE8';
    logSheet.getRange(lastRow, 1, 1, logRow.length).setBackground(bgColor);

    // [B-07] Invalidate HR context cache khi có thay đổi dữ liệu nhân sự
    const cacheInvalidationSheets = [
      CONFIG.SHEETS.NHAN_SU, CONFIG.SHEETS.UNG_VIEN, CONFIG.SHEETS.PHONG_VAN
    ];
    if (['CREATE', 'UPDATE', 'DELETE'].includes(action) &&
        cacheInvalidationSheets.includes(sheetName)) {
      invalidateHrContextCache();
    }

  } catch (e) {
    Logger.log('⚠️ writeAuditLog error: ' + e.message);
  }
}


// =============================================================================
// MIGRATION HELPER — Thêm cột Updated_At / Updated_By vào NHAN_SU
// Chạy 1 lần để migrate schema
// =============================================================================

/**
 * Thêm 2 cột Updated_At và Updated_By vào sheet NHAN_SU nếu chưa có
 * Cần cho B-11 optimistic locking
 */
function migrateNhanSuAddUpdatedAt() {
  const ss    = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(CONFIG.SHEETS.NHAN_SU);
  if (!sheet) {
    Logger.log('Sheet NHAN_SU không tồn tại');
    return;
  }

  const headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];

  if (!headers.includes('Updated_At')) {
    const nextCol = sheet.getLastColumn() + 1;
    sheet.getRange(1, nextCol).setValue('Updated_At');
    sheet.getRange(1, nextCol).setBackground('#2C2C2A').setFontColor('#FFF').setFontWeight('bold');
    sheet.getRange(2, nextCol, sheet.getLastRow() - 1, 1)
      .setNumberFormat('dd/MM/yyyy HH:mm:ss');
    Logger.log('✅ Đã thêm cột Updated_At vào NHAN_SU');
  }

  if (!headers.includes('Updated_By')) {
    const nextCol = sheet.getLastColumn() + 1;
    sheet.getRange(1, nextCol).setValue('Updated_By');
    sheet.getRange(1, nextCol).setBackground('#2C2C2A').setFontColor('#FFF').setFontWeight('bold');
    Logger.log('✅ Đã thêm cột Updated_By vào NHAN_SU');
  }

  Logger.log('Migration NHAN_SU hoàn tất.');
}



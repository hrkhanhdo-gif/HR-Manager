 * Format: "MM-DD" — không phụ thuộc năm
 * Thêm vào CONFIG nếu muốn customize
 */
const VN_PUBLIC_HOLIDAYS_FIXED = [
  '01-01', // Tết Dương lịch
  '04-30', // Giải phóng miền Nam
  '05-01', // Quốc tế Lao động
  '09-02', // Quốc khánh

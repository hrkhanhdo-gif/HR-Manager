/**
 * [B-07 FIX] buildHrContext() dùng ScriptCache để tránh 3 lần đọc sheet mỗi chat
 */
function buildHrContext() {
  const CACHE_KEY = 'HR_CONTEXT_CACHE';
  const cache     = CacheService.getScriptCache();

  // Thử lấy từ cache trước
  const cached = cache.get(CACHE_KEY);
  if (cached) {
    Logger.log('buildHrContext: Cache HIT');
    return cached;
  }

  // Cache MISS — build từ sheets
  const ss    = SpreadsheetApp.getActiveSpreadsheet();
  const lines = [];

  try {
    const nsSheet = ss.getSheetByName(CONFIG.SHEETS.NHAN_SU);
    if (nsSheet) {
      const nsData = nsSheet.getDataRange().getValues().slice(1).filter(r => r[0]);
      const active = nsData.filter(r => r[8] !== 'Đã nghỉ');
      const byDept = {};
      active.forEach(r => { const d = r[2] || 'Chưa phân'; byDept[d] = (byDept[d] || 0) + 1; });
      lines.push(`NHÂN SỰ: Tổng ${active.length} người đang làm việc.`);
      lines.push(`Phân bổ bộ phận: ${Object.entries(byDept).map(([k, v]) => `${k}(${v})`).join(', ')}`);
      lines.push(`Đã nghỉ (lịch sử): ${nsData.length - active.length} người`);
    }
  } catch (e) { Logger.log('buildHrContext nsSheet error: ' + e.message); }

  try {
    const uvSheet = ss.getSheetByName(CONFIG.SHEETS.UNG_VIEN);
    if (uvSheet) {
      const uvData    = uvSheet.getDataRange().getValues().slice(1).filter(r => r[0]);
      const byStatus  = {};
      uvData.forEach(r => { const s = r[5] || 'Mới nộp'; byStatus[s] = (byStatus[s] || 0) + 1; });
      lines.push(`TUYỂN DỤNG: ${uvData.length} ứng viên tổng cộng.`);
      lines.push(`Pipeline: ${Object.entries(byStatus).map(([k, v]) => `${k}(${v})`).join(', ')}`);
    }
  } catch (e) { Logger.log('buildHrContext uvSheet error: ' + e.message); }

  try {
    const bdays = getSinhNhatTuanNay();
    if (bdays.length > 0) {
      lines.push(`SINH NHẬT TUẦN NÀY: ${bdays.map(b => b.name + (b.days_until === 0 ? ' (hôm nay)' : ' (' + b.days_until + ' ngày)')).join(', ')}`);
    }
  } catch (e) {}

  const context = lines.join('\n') || 'Chưa có dữ liệu trong hệ thống.';

  // Lưu cache 5 phút (300 giây) — invalidate khi có CREATE/UPDATE/DELETE
  try {
    cache.put(CACHE_KEY, context, 300);
  } catch (e) {
    Logger.log('buildHrContext cache put error: ' + e.message);
  }

  Logger.log('buildHrContext: Cache SET');
  return context;
}

/**
 * Xóa HR context cache — gọi sau mỗi CREATE/UPDATE/DELETE quan trọng
 */
function invalidateHrContextCache() {
  try {
    CacheService.getScriptCache().remove('HR_CONTEXT_CACHE');
  } catch (e) {}
}



/**
 * Ngày lễ Tết Âm lịch (thay đổi theo năm — cần cập nhật mỗi năm)
 * Format: "YYYY-MM-DD"
 */
const VN_PUBLIC_HOLIDAYS_LUNAR = [
  // 2026
  '2026-01-28', '2026-01-29', '2026-01-30', '2026-01-31', '2026-02-01',
  // 2027 — cập nhật khi cần
  '2027-02-15', '2027-02-16', '2027-02-17', '2027-02-18', '2027-02-19',
];

/**
 * Lấy ngày Giỗ Tổ Hùng Vương theo năm (10/3 Âm lịch — xấp xỉ tháng 4)
 * Simplified: dùng ngày cố định cho đến khi có lunar calendar library
 */
const VN_HUNG_VUONG_BY_YEAR = {
  2026: '2026-04-07',
  2027: '2027-03-27',
};

/**
 * [B-17 FIX] countWorkDays() — trừ cả ngày lễ quốc gia VN
 * @param {Date} fromDate
 * @param {Date} toDate
 * @returns {number} Số ngày làm việc thực tế
 */
function countWorkDays(fromDate, toDate) {
  const year = fromDate.getFullYear();

  // Build holiday set cho năm tương ứng
  const holidays = new Set();

  // Ngày lễ cố định
  VN_PUBLIC_HOLIDAYS_FIXED.forEach(mmdd => {
    holidays.add(`${year}-${mmdd}`);
  });

  // Tết Âm lịch
  VN_PUBLIC_HOLIDAYS_LUNAR.forEach(d => holidays.add(d));

  // Giỗ Tổ Hùng Vương
  if (VN_HUNG_VUONG_BY_YEAR[year]) {
    holidays.add(VN_HUNG_VUONG_BY_YEAR[year]);
  }

  // Đọc thêm từ CONFIG nếu có (HR có thể thêm ngày lễ tùy chỉnh)
  try {
    const extraHolidays = PropertiesService.getScriptProperties().getProperty('EXTRA_HOLIDAYS_' + year);
    if (extraHolidays) {
      JSON.parse(extraHolidays).forEach(d => holidays.add(d));
    }
  } catch (e) {}

  let count = 0;
  const current = new Date(fromDate);
  current.setHours(0, 0, 0, 0);

  const end = new Date(toDate);
  end.setHours(0, 0, 0, 0);

  while (current <= end) {
    const dow     = current.getDay();
    const dateStr = Utilities.formatDate(current, 'Asia/Ho_Chi_Minh', 'yyyy-MM-dd');

    // Không tính T7 (6), CN (0), ngày lễ
    if (dow !== 0 && dow !== 6 && !holidays.has(dateStr)) {
      count++;
    }

    current.setDate(current.getDate() + 1);
  }

  return count;
}

/**
 * Admin có thể thêm ngày lễ bổ sung (quyết định bù lễ, nghỉ thêm...)
 * @param {number} year
 * @param {string[]} dates - Array "YYYY-MM-DD"
 */
function addExtraHolidays(year, dates) {
  const user = getCurrentUser();
  if (!hasPermission(user.role, 'ADMIN')) {
    return { success: false, error: 'Chỉ Admin mới thêm được ngày nghỉ' };
  }
  PropertiesService.getScriptProperties()
    .setProperty('EXTRA_HOLIDAYS_' + year, JSON.stringify(dates));
  invalidateHrContextCache();
  return { success: true, year, dates };
}


